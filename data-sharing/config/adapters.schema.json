{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dotlineform.com/schemas/data_sharing_adapters.schema.json",
  "title": "Data Sharing adapter registry",
  "type": "object",
  "required": ["schema_version", "dispatch", "adapters"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "data_sharing_adapters_v2"
    },
    "dispatch": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["data_domain", "operation", "adapter_id"],
        "additionalProperties": false,
        "properties": {
          "data_domain": {
            "type": "string",
            "minLength": 1
          },
          "operation": {
            "$ref": "#/$defs/operation"
          },
          "adapter_id": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "adapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "module", "label", "status", "portability", "data_domains", "capabilities"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "module": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "$ref": "#/$defs/status"
          },
          "portability": {
            "type": "object",
            "required": ["package"],
            "additionalProperties": false,
            "properties": {
              "package": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "data_domains": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "type": "object",
              "required": ["app", "label", "status", "selection_model", "paths", "source_write_targets", "sources", "config"],
              "additionalProperties": false,
              "properties": {
                "app": {
                  "type": "string",
                  "enum": ["docs-viewer", "studio", "analytics"]
                },
                "label": {
                  "type": "string",
                  "minLength": 1
                },
                "record_selectors": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "docs_scope": {
                      "type": "object",
                      "required": ["source", "required"],
                      "additionalProperties": false,
                      "properties": {
                        "source": {
                          "const": "docs_scope_config"
                        },
                        "required": {
                          "type": "boolean"
                        }
                      }
                    }
                  }
                },
                "status": {
                  "$ref": "#/$defs/status"
                },
                "selection_model": {
                  "$ref": "#/$defs/selection_model"
                },
                "paths": {
                  "$ref": "#/$defs/path_object"
                },
                "source_write_targets": {
                  "$ref": "#/$defs/path_object"
                },
                "sources": {
                  "$ref": "#/$defs/path_object"
                },
                "config": {
                  "$ref": "#/$defs/path_object"
                }
              }
            }
          },
          "capabilities": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["operation", "status", "selection_model", "input_formats", "output_formats", "path_contract", "activity"],
              "additionalProperties": false,
              "properties": {
                "operation": {
                  "$ref": "#/$defs/operation"
                },
                "status": {
                  "$ref": "#/$defs/status"
                },
                "message": {
                  "type": "string",
                  "minLength": 1
                },
                "selection_model": {
                  "$ref": "#/$defs/selection_model"
                },
                "input_formats": {
                  "$ref": "#/$defs/string_array"
                },
                "output_formats": {
                  "$ref": "#/$defs/string_array"
                },
                "path_contract": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "review_rows": {
                  "type": "object",
                  "required": ["fields"],
                  "additionalProperties": false,
                  "properties": {
                    "fields": {
                      "$ref": "#/$defs/string_array"
                    }
                  }
                },
                "requires_confirmation": {
                  "type": "boolean"
                },
                "apply_actions": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "required": ["id", "label", "status", "confirmation", "activity"],
                    "additionalProperties": false,
                    "properties": {
                      "id": {
                        "type": "string",
                        "minLength": 1
                      },
                      "label": {
                        "type": "string",
                        "minLength": 1
                      },
                      "status": {
                        "$ref": "#/$defs/status"
                      },
                      "confirmation": {
                        "type": "object",
                        "required": ["title", "body"],
                        "additionalProperties": false,
                        "properties": {
                          "title": {
                            "type": "string",
                            "minLength": 1
                          },
                          "body": {
                            "type": "string",
                            "minLength": 1
                          }
                        }
                      },
                      "activity": {
                        "$ref": "#/$defs/activity"
                      }
                    }
                  }
                },
                "activity": {
                  "$ref": "#/$defs/activity"
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "operation": {
      "type": "string",
      "enum": ["prepare", "list_returned", "review", "apply"]
    },
    "status": {
      "type": "string",
      "enum": ["active", "planned", "stub", "disabled"]
    },
    "selection_model": {
      "type": "string",
      "enum": ["documents", "records", "file_only", "none"]
    },
    "string_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "path_value": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/path_value"
          }
        }
      ]
    },
    "path_object": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/path_value"
      }
    },
    "activity": {
      "type": "object",
      "required": ["script_purpose", "record_groups"],
      "additionalProperties": false,
      "properties": {
        "script_purpose": {
          "type": "string",
          "minLength": 1
        },
        "record_groups": {
          "$ref": "#/$defs/string_array"
        }
      }
    }
  }
}
