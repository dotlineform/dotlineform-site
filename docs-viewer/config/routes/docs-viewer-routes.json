        "recently_added_url": "",
        "search_index_url": ""
      },
      "config_urls": {
        "docs_viewer": "/docs-viewer/config/defaults/docs-viewer-config.json",
        "report_registry": ""
      },
      "panels": {
        "index": {
          "enabled": true,
          "default_state": "normal"
        },
        "main": {
          "enabled": true,
          "default_view": "rendered-document"
        },
        "info": {
          "enabled": true,
          "default_view": "metadata-info"
        }
      },
      "view_policy": {
        "hidden_controls": ["bookmark"]
      }
    },
