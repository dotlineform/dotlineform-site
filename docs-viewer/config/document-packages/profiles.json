{
  "schema_version": "documents_prepare_profiles_v1",
  "configs": [
    {
      "id": "document-content",
      "label": "Document content",
      "description": "Document summaries, headings, and document body content.",
      "enabled": true,
      "data_domains": ["documents"],
      "target": {
        "format": "jsonl",
        "supported_formats": ["jsonl", "json"],
        "record_shape": "document_rows"
      },
      "content_format": {
        "format": "markdown",
        "supported_formats": ["markdown", "plain_text"]
      },
      "output": {
        "path_pattern": "{timestamp}-{data_domain}-{profile_id}.jsonl",
        "timestamp_format": "%Y%m%d-%H%M%S"
      },
      "selection": {
        "mode": "explicit_doc_ids",
        "include_descendants": true,
        "include_non_viewable": true,
        "supports_include_non_viewable": true,
        "supports_missing_summary_only": true,
        "default_missing_summary_only": false
      },
      "workflow": {
        "supports_return_import": true
      },
      "limits": {
        "max_documents": null,
        "max_chars_per_document": 50000,
        "max_total_chars": null,
        "truncate": {
          "enabled": true,
          "strategy": "paragraph_boundary",
          "marker": "[truncated]"
        }
      },
      "metadata": {
        "include": [
          "export_id",
          "config_id",
          "config_checksum",
          "data_domain",
          "scope",
          "generated_at",
          "selected_doc_ids",
          "source_last_updated",
          "counts"
        ]
      },
      "external_context": {
        "task": "Review and edit document content",
        "response_guidance": "Return only proposed changed fields keyed by doc_id. Preserve doc_id values exactly and do not invent document ids.",
        "field_descriptions": {
          "doc_id": "Stable document identifier. Preserve exactly in responses.",
          "title": "Document title.",
          "parent_id": "Current parent document id, if present.",
          "parent_title": "Current parent document title, if present.",
          "ancestors": "Current ancestor documents as id/title objects, ordered from root to nearest parent.",
          "children": "Current direct child documents as id/title objects.",
          "current_summary": "Existing document summary. Empty means a new summary may be needed.",
          "summary": "Proposed document summary.",
          "headings": "Headings extracted from the document.",
          "content": "Document body content extracted from rendered Docs Viewer HTML. Package-level content_format declares whether this value is Markdown or plain text."
        }
      },
      "document_fields": [
        {
          "source": "doc_id",
          "output_path": "doc_id",
          "required": true
        },
        {
          "source": "title",
          "output_path": "title",
          "required": true
        },
        {
          "source": "parent_id",
          "output_path": "parent_id",
          "include_if_empty": true
        },
        {
          "source": "parent_title",
          "output_path": "parent_title",
          "include_if_empty": true
        },
        {
          "source": "ancestors",
          "output_path": "ancestors",
          "default": []
        },
        {
          "source": "children",
          "output_path": "children",
          "default": []
        },
        {
          "source": "current_summary",
          "output_path": "current_summary",
          "default": ""
        },
        {
          "source": "summary",
          "output_path": "summary",
          "default": ""
        },
        {
          "source": "headings",
          "output_path": "headings",
          "default": [],
          "transforms": ["headings_from_rendered_html"]
        },
        {
          "source": "content",
          "output_path": "content",
          "required": true,
          "transforms": [
            "plain_text_from_rendered_html",
            "normalize_whitespace",
            "truncate_chars"
          ],
          "options": {
            "image_text_mode": "extract_text",
            "empty_image_mode": "marker"
          },
          "limit_key": "max_chars_per_document"
        }
      ],
      "notes": "Designed for external review, bulk LLM upload, and internal reporting where several selected docs should travel in the same file."
    },
    {
      "id": "document-tree",
      "label": "Document tree",
      "description": "Nested document parent-child tree with document ids and titles.",
      "enabled": true,
      "data_domains": ["documents"],
      "target": {
        "format": "json",
        "supported_formats": ["json"],
        "record_shape": "document_tree"
      },
      "output": {
        "path_pattern": "{timestamp}-{data_domain}-{profile_id}.json",
        "timestamp_format": "%Y%m%d-%H%M%S"
      },
      "selection": {
        "mode": "explicit_doc_ids",
        "include_descendants": true,
        "include_non_viewable": true,
        "supports_include_non_viewable": false,
        "supports_missing_summary_only": false,
        "default_missing_summary_only": false
      },
      "workflow": {
        "supports_return_import": false
      },
      "limits": {
        "max_documents": null,
        "max_chars_per_document": null,
        "max_total_chars": null,
        "truncate": {
          "enabled": false,
          "strategy": "hard",
          "marker": "[truncated]"
        }
      },
      "metadata": {
        "include": [
          "export_id",
          "config_id",
          "config_checksum",
          "data_domain",
          "scope",
          "generated_at",
          "selected_doc_ids",
          "source_last_updated",
          "counts"
        ]
      },
      "external_context": {
        "task": "Review document tree",
        "response_guidance": "Use the nested docs tree as read-only document hierarchy context.",
        "field_descriptions": {
          "doc_id": "Stable document identifier.",
          "title": "Document title."
        }
      },
      "document_fields": [
        {
          "source": "doc_id",
          "output_path": "doc_id",
          "required": true
        },
        {
          "source": "title",
          "output_path": "title",
          "required": true
        }
      ],
      "notes": "Export-only tree profile for sharing document hierarchy context without enabling returned-package review or apply."
    }
  ]
}
