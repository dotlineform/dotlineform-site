{
  "name": "dotlineform-site",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/workspaces/dotlineform-site/.venv/bin/python",
        "python.terminal.shellIntegration.enabled": false
      },
      "extensions": [
        "ms-python.python",
        "Shopify.ruby-lsp"
      ]
    }
  },
  "containerEnv": {
  "RBENV_ROOT": "/usr/local/rbenv",
  "PATH": "/usr/local/rbenv/shims:/usr/local/rbenv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin",
  "BUNDLE_PATH": "/workspaces/dotlineform-site/vendor/bundle",
  "DOTLINEFORM_PROJECTS_BASE_DIR": "/workspaces",
  "DOTLINEFORM_MEDIA_BASE_DIR": "/workspaces/.dotlineform-media",
  "MAKE_SRCSET_JOBS": "4"
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "remoteUser": "vscode"
}
