{
  "name": "dotlineform-site",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/workspaces/dotlineform-site/.venv/bin/python",
        "python.terminal.shellIntegration.enabled": false,
        "git.autofetch": true,
        "git.alwaysShowStagedChangesResourceGroup": true
      },
      "extensions": [
        "ms-python.python"
      ]
    }
  },
  "containerEnv": {
    "DOTLINEFORM_PROJECTS_BASE_DIR": "/workspaces",
    "DOTLINEFORM_MEDIA_BASE_DIR": "/workspaces/.dotlineform-media",
    "MAKE_SRCSET_JOBS": "4"
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "remoteUser": "vscode"
}
