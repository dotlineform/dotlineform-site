    "admin": {
      "label": "Admin",
      "include": ["admin-app/"],
      "exclude": ["admin-app/**/__pycache__/**"]
    },
    "analytics": {
      "label": "Analytics",
      "include": ["analytics-app/"],
      "exclude": ["analytics-app/**/__pycache__/**", "analytics-app/data/canonical/"]
    },
    "docs-viewer": {
      "label": "Docs Viewer",
      "include": ["docs-viewer/", "assets/docs/"],
      "exclude": ["docs-viewer/**/__pycache__/**", "docs-viewer/generated/"]
    },
    "public-site": {
      "label": "Public Site",
      "include": [
        "_config.yml",
        "_data/",
        "_includes/",
        "_layouts/",
        "_moments/",
        "_series/",
        "_work_details/",
        "_works/",
        "_works_print/",
        "analysis/",
        "assets/css/",
        "assets/js/",
        "catalogue/",
        "index.md",
        "library/",
        "moments/",
        "recent/",
        "series/",
        "work-details/",
        "works/"
      ],
      "exclude": ["_site/", "assets/data/"]
    },
    "studio": {
      "label": "Studio",
      "include": ["studio/", "data-sharing/"],
      "exclude": ["studio/**/__pycache__/**", "studio/data/generated/", "studio/data/canonical/", "studio/retired/"]
    },
    "all": {
      "label": "All",
      "include": [
        "_config.yml",
        "_data/",
        "_includes/",
        "_layouts/",
        "_moments/",
        "_series/",
        "_work_details/",
        "_works/",
        "_works_print/",
        "admin-app/",
        "analysis/",
        "analytics-app/",
        "assets/css/",
        "assets/docs/",
        "assets/js/",
        "catalogue/",
        "data-sharing/",
        "docs-viewer/",
        "index.md",
        "library/",
        "moments/",
        "recent/",
        "series/",
        "studio/",
        "work-details/",
        "works/"
      ],
      "exclude": [
        "_site/",
        "admin-app/**/__pycache__/**",
        "analytics-app/**/__pycache__/**",
        "analytics-app/data/canonical/",
        "assets/data/",
        "docs-viewer/**/__pycache__/**",
        "docs-viewer/generated/",
        "studio/**/__pycache__/**",
        "studio/data/canonical/",
        "studio/data/generated/",
        "studio/retired/"
