{
  "schema_version": "projection_contract_v1",
  "artifact_families": [
    {
      "id": "catalogue_canonical_source",
      "classification": "canonical_source",
      "repo_paths": [
        "assets/studio/data/catalogue/*.json",
        "_docs_catalogue/**"
      ],
      "public_output": {
        "policy": "forbidden",
        "paths": [
          "assets/studio/data/catalogue",
          "_docs_catalogue"
        ]
      },
      "jekyll_exclude_required": true,
      "owner_doc": "data-models-catalogue-source"
    },
    {
      "id": "catalogue_public_route_stubs",
      "classification": "public_projection",
      "repo_paths": [
        "_works/*.md",
        "_series/*.md",
        "_work_details/*.md",
        "_moments/*.md"
      ],
      "public_output": {
        "policy": "allowed",
        "paths": [
          "works/*/index.html",
          "series/*/index.html",
          "work_details/*/index.html",
          "moments/*/index.html"
        ]
      },
      "owner_doc": "data-models-catalogue-source"
    },
    {
      "id": "catalogue_public_indexes",
      "classification": "public_projection",
      "repo_paths": [
        "assets/data/works_index.json",
        "assets/data/series_index.json",
        "assets/data/moments_index.json",
        "assets/data/recent_index.json"
      ],
      "public_output": {
        "policy": "required",
        "paths": [
          "assets/data/works_index.json",
          "assets/data/series_index.json",
          "assets/data/moments_index.json",
          "assets/data/recent_index.json"
        ]
      },
      "owner_doc": "data-models-catalogue-indexes"
    },
    {
      "id": "catalogue_public_record_payloads",
      "classification": "public_projection",
      "repo_paths": [
        "assets/works/index/*.json",
        "assets/series/index/*.json",
        "assets/moments/index/*.json"
      ],
      "public_output": {
        "policy": "required",
        "paths": [
          "assets/works/index/*.json",
          "assets/series/index/*.json",
          "assets/moments/index/*.json"
        ]
      },
      "owner_doc": "data-models-catalogue-indexes"
    },
    {
      "id": "catalogue_public_search",
      "classification": "public_projection",
      "repo_paths": [
        "assets/data/search/catalogue/index.json"
      ],
      "public_output": {
        "policy": "required",
        "paths": [
          "assets/data/search/catalogue/index.json"
        ]
      },
      "owner_doc": "search-build-pipeline-catalogue"
    },
    {
      "id": "catalogue_studio_lookup_projections",
      "classification": "studio_projection",
      "repo_paths": [
        "assets/studio/data/catalogue_lookup/**",
        "assets/studio/data/catalogue_field_registry.json",
        "assets/studio/data/work_storage_index.json"
      ],
      "public_output": {
        "policy": "forbidden",
        "paths": [
          "assets/studio/data/catalogue_lookup",
          "assets/studio/data/catalogue_field_registry.json",
          "assets/studio/data/work_storage_index.json"
        ]
      },
      "jekyll_exclude_required": true,
      "owner_doc": "data-models-catalogue"
    },
    {
      "id": "studio_tag_source_data",
      "classification": "canonical_source",
      "repo_paths": [
        "assets/studio/data/tag_registry.json",
        "assets/studio/data/tag_aliases.json",
        "assets/studio/data/tag_assignments.json",
        "assets/studio/data/tag_groups.json"
      ],
      "public_output": {
        "policy": "forbidden",
        "paths": [
          "assets/studio/data/tag_registry.json",
          "assets/studio/data/tag_aliases.json",
          "assets/studio/data/tag_assignments.json",
          "assets/studio/data/tag_groups.json"
        ]
      },
      "jekyll_exclude_required": true,
      "owner_doc": "data-models-studio"
    },
    {
      "id": "studio_config_and_ui_text",
      "classification": "studio_projection",
      "repo_paths": [
        "assets/studio/data/studio_config.json",
        "assets/studio/data/ui_text/*.json",
        "assets/studio/data/activity_contract.json"
      ],
      "public_output": {
        "policy": "forbidden",
        "paths": [
          "assets/studio/data/studio_config.json",
          "assets/studio/data/ui_text",
          "assets/studio/data/activity_contract.json"
        ]
      },
      "jekyll_exclude_required": true,
      "owner_doc": "config-studio-config-json"
    },
    {
      "id": "studio_docs_source",
      "classification": "canonical_source",
      "repo_paths": [
        "_docs/*.md"
      ],
      "public_output": {
        "policy": "forbidden",
        "paths": [
          "_docs"
        ]
      },
      "jekyll_exclude_required": true,
      "owner_doc": "data-models-studio"
    },
    {
      "id": "studio_docs_payloads",
      "classification": "docs_viewer_payload",
      "repo_paths": [
        "assets/data/docs/scopes/studio/index.json",
        "assets/data/docs/scopes/studio/by-id/*.json",
        "assets/data/docs/scopes/studio/references/**"
      ],
      "public_output": {
        "policy": "forbidden",
        "paths": [
          "assets/data/docs/scopes/studio"
        ]
      },
      "jekyll_exclude_required": true,
      "owner_doc": "data-models-studio"
    },
    {
      "id": "studio_docs_search",
      "classification": "docs_viewer_payload",
      "repo_paths": [
        "assets/data/search/studio/index.json"
      ],
      "public_output": {
        "policy": "forbidden",
        "paths": [
          "assets/data/search/studio"
        ]
      },
      "jekyll_exclude_required": true,
      "owner_doc": "search-build-pipeline-studio"
    },
    {
      "id": "library_docs_source",
      "classification": "canonical_source",
      "repo_paths": [
        "_docs_library/*.md"
      ],
      "public_output": {
        "policy": "forbidden",
        "paths": [
          "_docs_library"
        ]
      },
      "jekyll_exclude_required": true,
      "owner_doc": "data-models-library"
    },
    {
      "id": "library_docs_payloads",
      "classification": "docs_viewer_payload",
      "repo_paths": [
        "assets/data/docs/scopes/library/index.json",
        "assets/data/docs/scopes/library/by-id/*.json"
      ],
      "public_output": {
        "policy": "required",
        "paths": [
          "assets/data/docs/scopes/library/index.json",
          "assets/data/docs/scopes/library/by-id/*.json"
        ]
      },
      "owner_doc": "data-models-library"
    },
    {
      "id": "library_docs_search",
      "classification": "docs_viewer_payload",
      "repo_paths": [
        "assets/data/search/library/index.json"
      ],
      "public_output": {
        "policy": "required",
        "paths": [
          "assets/data/search/library/index.json"
        ]
      },
      "owner_doc": "search-build-pipeline-library"
    },
    {
      "id": "analysis_docs_source",
      "classification": "canonical_source",
      "repo_paths": [
        "_docs_analysis/**/*.md"
      ],
      "public_output": {
        "policy": "forbidden",
        "paths": [
          "_docs_analysis"
        ]
      },
      "jekyll_exclude_required": true,
      "owner_doc": "data-models-analysis"
    },
    {
      "id": "analysis_docs_payloads",
      "classification": "docs_viewer_payload",
      "repo_paths": [
        "assets/data/docs/scopes/analysis/index.json",
        "assets/data/docs/scopes/analysis/by-id/*.json",
        "assets/data/docs/scopes/analysis/references/**"
      ],
      "public_output": {
        "policy": "required",
        "paths": [
          "assets/data/docs/scopes/analysis/index.json",
          "assets/data/docs/scopes/analysis/by-id/*.json"
        ]
      },
      "owner_doc": "data-models-analysis"
    },
    {
      "id": "analysis_docs_search",
      "classification": "docs_viewer_payload",
      "repo_paths": [
        "assets/data/search/analysis/index.json"
      ],
      "public_output": {
        "policy": "required",
        "paths": [
          "assets/data/search/analysis/index.json"
        ]
      },
      "owner_doc": "search-build-pipeline-analysis"
    },
    {
      "id": "docs_viewer_runtime",
      "classification": "public_runtime_asset",
      "repo_paths": [
        "assets/docs-viewer/js/*.js",
        "assets/docs-viewer/css/*.css",
        "assets/docs-viewer/data/ui-text.json",
        "assets/docs-viewer/data/docs-viewer-public-config.json"
      ],
      "public_output": {
        "policy": "required",
        "paths": [
          "assets/docs-viewer/js/docs-viewer.js",
          "assets/docs-viewer/css/docs-viewer.css",
          "assets/docs-viewer/data/docs-viewer-public-config.json"
        ]
      },
      "owner_doc": "docs-viewer-runtime-boundary"
    },
    {
      "id": "docs_viewer_management_runtime",
      "classification": "studio_projection",
      "repo_paths": [
        "assets/docs-viewer/js/docs-viewer-management*.js",
        "assets/docs-viewer/js/docs-html-import*.js",
        "assets/docs-viewer/css/docs-viewer-management.css",
        "assets/docs-viewer/data/docs-viewer-config.json"
      ],
      "public_output": {
        "policy": "allowed",
        "paths": [
          "assets/docs-viewer/js/docs-viewer-management*.js",
          "assets/docs-viewer/js/docs-html-import*.js",
          "assets/docs-viewer/css/docs-viewer-management.css",
          "assets/docs-viewer/data/docs-viewer-config.json"
        ]
      },
      "owner_doc": "docs-viewer-management"
    },
    {
      "id": "public_search_policy",
      "classification": "public_projection",
      "repo_paths": [
        "assets/data/search/policy.json"
      ],
      "public_output": {
        "policy": "required",
        "paths": [
          "assets/data/search/policy.json"
        ]
      },
      "owner_doc": "search-public-ui-contract"
    },
    {
      "id": "public_media_and_thumbnails",
      "classification": "public_runtime_asset",
      "repo_paths": [
        "assets/works/img/**",
        "assets/work_details/img/**",
        "assets/moments/img/**",
        "assets/docs/**"
      ],
      "public_output": {
        "policy": "allowed",
        "paths": [
          "assets/works/img/**",
          "assets/work_details/img/**",
          "assets/moments/img/**",
          "assets/docs/**"
        ]
      },
      "owner_doc": "scripts-build-catalogue-json"
    },
    {
      "id": "studio_app_assets",
      "classification": "studio_app_asset",
      "repo_paths": [
        "assets/studio/css/**",
        "assets/studio/js/**",
        "assets/studio/data/**"
      ],
      "public_output": {
        "policy": "forbidden",
        "paths": [
          "assets/studio"
        ]
      },
      "jekyll_exclude_required": true,
      "owner_doc": "local-studio-app-public-surface"
    },
    {
      "id": "ui_catalogue_demo_assets",
      "classification": "studio_app_asset",
      "repo_paths": [
        "assets/ui-catalogue/**",
        "assets/docs/ui-catalogue/**",
        "_ui_catalogue_notes/**",
        "_includes/ui_catalogue_notes/**"
      ],
      "public_output": {
        "policy": "forbidden",
        "paths": [
          "assets/ui-catalogue",
          "assets/docs/ui-catalogue",
          "_ui_catalogue_notes",
          "_includes/ui_catalogue_notes"
        ]
      },
      "jekyll_exclude_required": true,
      "owner_doc": "ui-catalogue"
    },
    {
      "id": "local_working_output",
      "classification": "local_working_output",
      "repo_paths": [
        "var/**",
        "logs/**"
      ],
      "public_output": {
        "policy": "forbidden",
        "paths": [
          "var",
          "logs"
        ]
      },
      "jekyll_exclude_required": true,
      "owner_doc": "local-setup"
    }
  ],
  "field_leak_rules": [
    {
      "id": "catalogue_source_media_paths",
      "description": "Source media path fields can stay in canonical catalogue source but must not appear in public JSON or search projections.",
      "fields": [
        "project_folder",
        "project_subfolder",
        "project_filename",
        "details_subfolder",
        "source_image_file",
        "provenance"
      ],
      "public_paths": [
        "assets/data/works_index.json",
        "assets/data/series_index.json",
        "assets/data/moments_index.json",
        "assets/data/recent_index.json",
        "assets/works/index/*.json",
        "assets/series/index/*.json",
        "assets/moments/index/*.json",
        "assets/data/search/catalogue/index.json"
      ]
    }
  ],
  "public_docs_viewer": {
    "config_path": "assets/docs-viewer/data/docs-viewer-public-config.json",
    "allowed_scope_ids": [
      "library",
      "analysis"
    ]
  },
  "public_html_forbidden_hrefs": [
    "href=\"/studio/\"",
    "href=\"/docs/\"",
    "href=\"/docs/?"
  ],
  "public_source_reference_audit": {
    "scan_paths": [
      "_layouts/**/*.html",
      "_includes/**/*.html",
      "assets/js/**/*.js",
      "assets/css/**/*.css",
      "*.md"
    ],
    "ignore_paths": [
      "_includes/studio_header_nav.html"
    ],
    "forbidden_substrings": [
      "assets/studio/",
      "/assets/studio/",
      "assets/data/docs/scopes/studio",
      "/assets/data/docs/scopes/studio",
      "assets/data/search/studio",
      "/assets/data/search/studio",
      "href=\"/studio/",
      "href='/studio/",
      "baseurl + '/studio/",
      "baseurl + \"/studio/",
      "href=\"/docs/?scope=studio",
      "href='/docs/?scope=studio"
    ]
  }
}
