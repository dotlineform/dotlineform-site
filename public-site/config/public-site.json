{
  "schema_version": "public_site_config_v1",
  "site": {
    "title": "dotlineform",
    "url": "https://www.dotlineform.com",
    "baseurl": "",
    "live_url": "https://www.dotlineform.com",
    "timezone": "Europe/London"
  },
  "assets": {
    "version": "static"
  },
  "runtime_text": {
    "loading": "loading...",
    "unavailable": "info not available"
  },
  "media": {
    "base": "https://media.dotlineform.com",
    "image_works": "/works/img",
    "files_works": "/works/files",
    "image_work_details": "/work_details/img",
    "image_moments": "/moments/img"
  },
  "thumbs": {
    "base": "",
    "works": "/assets/works/img",
    "work_details": "/assets/work_details/img",
    "moments": "/assets/moments/img"
  },
  "home_media": {
    "base": "https://media.dotlineform.com",
    "prefix": "/home/img"
  },
  "docs_viewer": {
    "route_config_url": "/docs-viewer/config/routes/docs-viewer-public-routes.json",
    "entrypoint": "/docs-viewer/runtime/js/docs-viewer-public.js",
    "stylesheet": "/docs-viewer/static/css/docs-viewer.css"
  },
  "output": {
    "default_destination": "_public_site",
    "marker_file": ".public-site-artifact",
    "nojekyll_file": ".nojekyll"
  },
  "root_artifacts": [
    "CNAME",
    "favicon.ico",
    "favicon-16x16.png",
    "favicon-32x32.png",
    "apple-touch-icon.png",
    "apple-touch-icon-precomposed.png",
    "android-chrome-192x192.png",
    "android-chrome-512x512.png",
    "safari-pinned-tab.svg",
    "site.webmanifest"
  ],
  "audit": {
    "required_files": [
      ".public-site-artifact",
      ".nojekyll",
      "index.html",
      "about/index.html",
      "recent/index.html",
      "series/index.html",
      "works/index.html",
      "work-details/index.html",
      "moments/index.html",
      "catalogue/search/index.html",
      "library/index.html",
      "analysis/index.html",
      "CNAME",
      "favicon.ico",
      "favicon-16x16.png",
      "favicon-32x32.png",
      "apple-touch-icon.png",
      "apple-touch-icon-precomposed.png",
      "android-chrome-192x192.png",
      "android-chrome-512x512.png",
      "safari-pinned-tab.svg",
      "site.webmanifest",
      "404.html"
    ],
    "denied_path_prefixes": [
      ".git/",
      ".github/",
      ".codex/",
      ".devcontainer/",
      ".vscode/",
      ".pytest_cache/",
      ".pycache/",
      "__pycache__/",
      ".bundle/",
      "node_modules/",
      "vendor/",
      "_site/",
      "_public_site/",
      "var/",
      "logs/",
      "_layouts/",
      "_includes/",
      "admin-app/",
      "analytics-app/",
      "studio/",
      "data/",
      "data-sharing/",
      "docs-viewer/source/",
      "docs-viewer/services/",
      "docs-viewer/build/",
      "docs-viewer/bin/",
      "docs-viewer/shell/",
      "docs-viewer/tests/",
      "docs-viewer/runtime/js/reports/"
    ],
    "denied_file_patterns": [
      "Gemfile",
      "Gemfile.lock",
      ".ruby-version",
      "_config.yml",
      "README.md",
      "AGENTS.md",
      "LICENSE",
      "requirements.txt",
      "*.xlsx",
      "*.xls",
      "*.pyc",
      ".DS_Store",
      "docs-html-import*.js",
      "docs-viewer-manage.js",
      "docs-viewer-management*.js",
      "docs-viewer-config.json",
      "docs-viewer-service.json",
      "docs-viewer-routes.json"
    ],
    "denied_html_tokens": [
      "{{",
      "{%"
    ]
  }
}
