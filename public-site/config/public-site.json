{
  "schema_version": "public_site_config_v1",
  "site": {
    "title": "dotlineform",
    "url": "https://www.dotlineform.com",
    "baseurl": "",
    "live_url": "https://www.dotlineform.com",
    "timezone": "Europe/London"
  },
  "assets": {
    "version": "static"
  },
  "runtime_text": {
    "loading": "loading...",
    "unavailable": "info not available"
  },
  "media": {
    "base": "https://media.dotlineform.com",
    "image_works": "/works/img",
    "files_works": "/works/files",
    "image_work_details": "/work_details/img",
    "image_moments": "/moments/img"
  },
  "thumbs": {
    "base": "",
    "works": "/assets/works/img",
    "work_details": "/assets/work_details/img",
    "moments": "/assets/moments/img"
  },
  "home_media": {
    "base": "https://media.dotlineform.com",
    "prefix": "/home/img"
  },
  "docs_viewer": {
    "route_config_url": "/docs-viewer/config/routes/docs-viewer-public-routes.json",
    "entrypoint": "/docs-viewer/runtime/js/docs-viewer-public.js",
    "stylesheet": "/docs-viewer/static/css/docs-viewer.css"
  },
  "output": {
    "default_destination": "_public_site",
    "marker_file": ".public-site-artifact",
    "nojekyll_file": ".nojekyll"
  },
  "root_artifacts": [
    "CNAME",
    "favicon.ico",
    "favicon-16x16.png",
    "favicon-32x32.png",
    "apple-touch-icon.png",
    "apple-touch-icon-precomposed.png",
    "android-chrome-192x192.png",
    "android-chrome-512x512.png",
    "safari-pinned-tab.svg",
    "site.webmanifest"
  ],
  "public_files": [
    "assets/css/main.css",
    "assets/site/dotlineform.png",
    "assets/js/catalogue-search.js",
    "assets/js/moment.js",
    "assets/js/public-catalogue-runtime.js",
    "assets/js/recent-index.js",
    "assets/js/search/catalogue-search-runtime.js",
    "assets/js/search/search-performance.js",
    "assets/js/search/search-policy.js",
    "assets/js/series-index.js",
    "assets/js/site-nav.js",
    "assets/js/swipe-nav.js",
    "assets/js/theme-toggle.js",
    "assets/js/work-detail-page.js",
    "assets/js/work-page.js",
    "assets/js/work.js",
    "assets/js/works-index.js",
    "assets/data/moments_index.json",
    "assets/data/recent_index.json",
    "assets/data/series_index.json",
    "assets/data/works_index.json",
    "assets/data/search/analysis/index.json",
    "assets/data/search/catalogue/index.json",
    "assets/data/search/library/index.json",
    "assets/data/search/policy.json",
    "docs-viewer/config/defaults/docs-viewer-public-config.json",
    "docs-viewer/config/routes/docs-viewer-public-routes.json",
    "docs-viewer/config/ui-text/public.json",
    "docs-viewer/static/css/docs-viewer.css"
  ],
  "public_trees": [
    "assets/docs/interactive/library",
    "assets/data/docs/scopes/analysis",
    "assets/data/docs/scopes/library",
    "assets/moments/img",
    "assets/moments/index",
    "assets/series/index",
    "assets/work_details/img",
    "assets/works/img",
    "assets/works/index"
  ],
  "docs_viewer_public_runtime": {
    "entrypoints": [
      "docs-viewer/runtime/js/docs-viewer-public.js"
    ],
    "dynamic_files": [
      "docs-viewer/runtime/js/docs-viewer-metadata-info-view.js"
    ]
  },
  "audit": {
    "required_files": [
      ".public-site-artifact",
      ".nojekyll",
      "index.html",
      "about/index.html",
      "recent/index.html",
      "series/index.html",
      "works/index.html",
      "work-details/index.html",
      "moments/index.html",
      "catalogue/search/index.html",
      "library/index.html",
      "analysis/index.html",
      "CNAME",
      "favicon.ico",
      "favicon-16x16.png",
      "favicon-32x32.png",
      "apple-touch-icon.png",
      "apple-touch-icon-precomposed.png",
      "android-chrome-192x192.png",
      "android-chrome-512x512.png",
      "safari-pinned-tab.svg",
      "site.webmanifest",
      "assets/css/main.css",
      "assets/js/public-catalogue-runtime.js",
      "assets/js/series-index.js",
      "assets/js/work-page.js",
      "assets/js/search/search-policy.js",
      "assets/data/series_index.json",
      "assets/data/works_index.json",
      "assets/data/search/catalogue/index.json",
      "assets/series/index/105.json",
      "assets/works/index/00008.json",
      "assets/work_details/img/00001-001-thumb-96.webp",
      "assets/moments/index/compiled.json",
      "assets/docs/interactive/library/coincidence-salience-demo.html",
      "assets/data/docs/scopes/library/index-tree.json",
      "assets/data/docs/scopes/library/by-id/library.json",
      "assets/data/docs/scopes/analysis/index-tree.json",
      "assets/data/search/library/index.json",
      "assets/data/search/analysis/index.json",
      "docs-viewer/config/defaults/docs-viewer-public-config.json",
      "docs-viewer/config/routes/docs-viewer-public-routes.json",
      "docs-viewer/config/ui-text/public.json",
      "docs-viewer/static/css/docs-viewer.css",
      "docs-viewer/runtime/js/docs-viewer-public.js",
      "docs-viewer/runtime/js/docs-viewer-app-boot.js",
      "docs-viewer/runtime/js/docs-viewer-metadata-info-view.js",
      "404.html"
    ],
    "required_directories": [
      "assets/data/docs/scopes/analysis/by-id",
      "assets/data/docs/scopes/library/by-id",
      "assets/moments/img",
      "assets/series/index",
      "assets/work_details/img",
      "assets/works/img",
      "assets/works/index",
      "docs-viewer/runtime/js"
    ],
    "denied_path_prefixes": [
      ".git/",
      ".github/",
      ".codex/",
      ".devcontainer/",
      ".vscode/",
      ".pytest_cache/",
      ".pycache/",
      "__pycache__/",
      ".bundle/",
      "node_modules/",
      "vendor/",
      "_site/",
      "_public_site/",
      "var/",
      "logs/",
      "_layouts/",
      "_includes/",
      "admin-app/",
      "analytics-app/",
      "studio/",
      "data/",
      "data-sharing/",
      "docs-viewer/source/",
      "docs-viewer/services/",
      "docs-viewer/build/",
      "docs-viewer/bin/",
      "docs-viewer/shell/",
      "docs-viewer/tests/",
      "docs-viewer/runtime/js/reports/"
    ],
    "denied_file_patterns": [
      "Gemfile",
      "Gemfile.lock",
      ".ruby-version",
      "_config.yml",
      "README.md",
      "AGENTS.md",
      "LICENSE",
      "requirements.txt",
      "*.xlsx",
      "*.xls",
      "*.pyc",
      ".DS_Store",
      "docs-html-import*.js",
      "docs-viewer-manage.js",
      "docs-viewer-management*.js",
      "docs-viewer-config.json",
      "docs-viewer-service.json",
      "docs-viewer-routes.json"
    ],
    "denied_html_tokens": [
      "{{",
      "{%"
    ]
  }
}
