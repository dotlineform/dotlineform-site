{
  "schema": "activity_contract_v1",
  "status": "v1_initial_contract",
  "last_updated": "2026-05-08",
  "source_doc": "/docs/?scope=studio&doc=site-request-studio-unified-activity-log",
  "inventory_doc": "/docs/?scope=studio&doc=site-request-studio-unified-activity-log-inventory",
  "description": "Registry for Studio user actions and the script-purpose rows that may appear in the unified activity log.",
  "pages": {
    "catalogue-work": {
      "label": "catalogue work editor",
      "route": "/studio/catalogue-work/",
      "actions": {
        "save-work": {
          "label": "save work",
          "status": "v1-target",
          "control_id": "catalogueWorkSave",
          "control_selector": "#catalogueWorkSave",
          "control_label": "Save",
          "endpoint": "/catalogue/work/save",
          "record_family": "work",
          "record_id_field": "work_id",
          "no_change_activity": "skip",
          "report_forced_rewrites": true,
          "notes": "Covers metadata edits to one existing work. Create, bulk save, publish, delete, preview, prose import, and media refresh are later actions.",
          "script_purposes": [
            {
              "id": "save-canonical-data",
              "optional": false,
              "when": "core work source JSON changes"
            },
            {
              "id": "rebuild-published-work-data",
              "optional": true,
              "when": "published work output is attempted"
            },
            {
              "id": "rebuild-lookups",
              "optional": true,
              "when": "Studio lookup refresh is attempted"
            },
            {
              "id": "update-search",
              "optional": true,
              "when": "catalogue search rebuild is attempted"
            }
          ]
        }
      }
    },
    "catalogue-work-detail": {
      "label": "catalogue work detail editor",
      "route": "/studio/catalogue-work-detail/",
      "actions": {
        "save-work-detail": {
          "label": "save work detail",
          "status": "v1-target",
          "control_id": "catalogueWorkDetailSave",
          "control_selector": "#catalogueWorkDetailSave",
          "control_label": "Save",
          "endpoint": "/catalogue/work-detail/save",
          "record_family": "work_detail",
          "record_id_field": "detail_uid",
          "no_change_activity": "skip",
          "report_forced_rewrites": true,
          "notes": "Covers metadata edits to one existing work detail. Public output is parent-work scoped. Create, bulk save, publish, delete, preview, and media refresh are later actions.",
          "script_purposes": [
            {
              "id": "save-canonical-data",
              "optional": false,
              "when": "core work detail source JSON changes"
            },
            {
              "id": "rebuild-published-work-data",
              "optional": true,
              "when": "published parent work output is attempted"
            },
            {
              "id": "rebuild-lookups",
              "optional": true,
              "when": "Studio lookup refresh is attempted"
            },
            {
              "id": "update-search",
              "optional": true,
              "when": "catalogue search rebuild is attempted"
            }
          ]
        }
      }
    },
    "catalogue-series": {
      "label": "catalogue series editor",
      "route": "/studio/catalogue-series/",
      "actions": {
        "save-series": {
          "label": "save series",
          "status": "v1-target",
          "control_id": "catalogueSeriesSave",
          "control_selector": "#catalogueSeriesSave",
          "control_label": "Save",
          "endpoint": "/catalogue/series/save",
          "record_family": "series",
          "record_id_field": "series_id",
          "no_change_activity": "skip",
          "report_forced_rewrites": true,
          "notes": "Covers metadata edits to one existing series and member work membership updates saved through the same button. Create, publish, delete, preview, and prose import are later actions.",
          "script_purposes": [
            {
              "id": "save-canonical-data",
              "optional": false,
              "when": "core series source JSON or member work source JSON changes"
            },
            {
              "id": "rebuild-published-series-data",
              "optional": true,
              "when": "published series/work output is attempted"
            },
            {
              "id": "rebuild-lookups",
              "optional": true,
              "when": "Studio lookup refresh is attempted"
            },
            {
              "id": "update-search",
              "optional": true,
              "when": "catalogue search rebuild is attempted"
            }
          ]
        }
      }
    },
    "catalogue-moment": {
      "label": "catalogue moment editor",
      "route": "/studio/catalogue-moment/",
      "actions": {
        "save-moment": {
          "label": "save moment",
          "status": "v1-target",
          "control_id": "catalogueMomentSave",
          "control_selector": "#catalogueMomentSave",
          "control_label": "Save",
          "endpoint": "/catalogue/moment/save",
          "record_family": "moment",
          "record_id_field": "moment_id",
          "no_change_activity": "skip",
          "report_forced_rewrites": true,
          "notes": "Covers metadata edits to one existing moment. Moment saves do not currently write Studio catalogue lookup payloads; published moment builds update moment runtime data and search.",
          "script_purposes": [
            {
              "id": "save-canonical-data",
              "optional": false,
              "when": "core moment source JSON changes"
            },
            {
              "id": "rebuild-published-moment-data",
              "optional": true,
              "when": "published moment output is attempted"
            },
            {
              "id": "update-search",
              "optional": true,
              "when": "catalogue search rebuild is attempted"
            }
          ]
        }
      }
    }
  },
  "script_purposes": {
    "save-canonical-data": {
      "label": "save canonical data",
      "status": "v1-target",
      "artifact_families": ["source-json"],
      "detail_templates": [
        "Saved canonical work record {work_id}"
      ]
    },
    "rebuild-published-work-data": {
      "label": "rebuild published work data",
      "status": "v1-target",
      "artifact_families": ["work-json", "works-index-json", "series-index-json", "recent-index-json"],
      "detail_templates": [
        "Updated published work JSON for {work_id}"
      ]
    },
    "rebuild-published-series-data": {
      "label": "rebuild published series data",
      "status": "v1-target",
      "artifact_families": ["series-json", "work-json", "works-index-json", "series-index-json", "recent-index-json"],
      "detail_templates": [
        "Updated published series/work JSON for series {series_id}"
      ]
    },
    "rebuild-published-moment-data": {
      "label": "rebuild published moment data",
      "status": "v1-target",
      "artifact_families": ["moment-json", "moments-index-json"],
      "detail_templates": [
        "Updated published moment JSON for {moment_id}"
      ]
    },
    "rebuild-lookups": {
      "label": "rebuild lookups",
      "status": "v1-target",
      "artifact_families": ["studio-lookup"],
      "detail_templates": [
        "Refreshed catalogue lookup data for work {work_id}"
      ]
    },
    "update-search": {
      "label": "update search",
      "status": "v1-target",
      "artifact_families": ["catalogue-search"],
      "detail_templates": [
        "Rebuilt catalogue search for work {work_id}"
      ]
    }
  }
}
