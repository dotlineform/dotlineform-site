          "endpoint": "/catalogue/publication-apply",
          "record_family": "work_detail",
          "record_id_field": "detail_uid",
          "no_change_activity": "skip",
          "report_forced_rewrites": true,
          "notes": "Covers unpublication apply for one work detail. Cleanup and public output are parent-work scoped.",
          "script_purposes": [
            {
              "id": "save-canonical-data",
