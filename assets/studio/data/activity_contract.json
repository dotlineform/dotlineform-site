{
  "schema": "activity_contract_v1",
  "status": "v1_initial_contract",
  "last_updated": "2026-05-08",
  "source_doc": "/docs/?scope=studio&doc=site-request-studio-unified-activity-log",
  "inventory_doc": "/docs/?scope=studio&doc=site-request-studio-unified-activity-log-inventory",
  "description": "Registry for Studio user actions and the script-purpose rows that may appear in the unified activity log.",
  "pages": {
    "catalogue-work": {
      "label": "catalogue work editor",
      "route": "/studio/catalogue-work/",
      "actions": {
        "save-work": {
          "label": "save work",
          "status": "v1-target",
          "control_id": "catalogueWorkSave",
          "control_selector": "#catalogueWorkSave",
          "control_label": "Save",
          "endpoint": "/catalogue/work/save",
          "record_family": "work",
          "record_id_field": "work_id",
          "no_change_activity": "skip",
          "report_forced_rewrites": true,
          "notes": "Covers metadata edits to one existing work. Create, bulk save, publish, delete, preview, prose import, and media refresh are later actions.",
          "script_purposes": [
            {
              "id": "save-canonical-data",
              "optional": false,
              "when": "core work source JSON changes"
            },
            {
              "id": "rebuild-published-work-data",
              "optional": true,
              "when": "published work output is attempted"
            },
            {
              "id": "rebuild-lookups",
              "optional": true,
              "when": "Studio lookup refresh is attempted"
            },
            {
              "id": "update-search",
              "optional": true,
              "when": "catalogue search rebuild is attempted"
            }
          ]
        },
        "create-work": {
          "label": "create work",
          "status": "v1-target",
          "control_id": "catalogueWorkSave",
          "control_selector": "#catalogueWorkSave",
          "control_label": "Save",
          "endpoint": "/catalogue/work/create",
          "record_family": "work",
          "record_id_field": "work_id",
          "no_change_activity": "skip",
          "report_forced_rewrites": false,
          "notes": "Covers source-only draft work creation from work-editor new mode. Moment creation is excluded from this create pattern because it is currently an import/apply workflow.",
          "script_purposes": [
            {
              "id": "save-canonical-data",
              "optional": false,
              "when": "new draft work source JSON is written"
            },
            {
              "id": "rebuild-lookups",
              "optional": true,
              "when": "Studio lookup refresh is attempted after create"
            }
          ]
        },
        "publish-work": {
          "label": "publish work",
          "status": "v1-target",
          "control_id": "catalogueWorkPublication",
          "control_selector": "#catalogueWorkPublication",
          "control_label": "Publish",
          "endpoint": "/catalogue/publication-apply",
          "record_family": "work",
          "record_id_field": "work_id",
          "no_change_activity": "skip",
          "report_forced_rewrites": true,
          "notes": "Covers publication apply after the preview/confirmation flow for one work.",
          "script_purposes": [
            {
              "id": "save-canonical-data",
              "optional": false,
              "when": "work status or related publication source data changes"
            },
            {
              "id": "rebuild-published-work-data",
              "optional": true,
              "when": "published work output is attempted"
            },
            {
              "id": "rebuild-lookups",
              "optional": true,
              "when": "Studio lookup refresh is attempted"
            },
            {
              "id": "update-search",
              "optional": true,
              "when": "catalogue search rebuild is attempted"
            }
          ]
        },
        "unpublish-work": {
          "label": "unpublish work",
          "status": "v1-target",
          "control_id": "catalogueWorkPublication",
          "control_selector": "#catalogueWorkPublication",
          "control_label": "Unpublish",
          "endpoint": "/catalogue/publication-apply",
          "record_family": "work",
          "record_id_field": "work_id",
          "no_change_activity": "skip",
          "report_forced_rewrites": true,
          "notes": "Covers unpublication apply after the preview/confirmation flow for one work.",
          "script_purposes": [
            {
              "id": "save-canonical-data",
              "optional": false,
              "when": "work status source data changes"
            },
            {
              "id": "rebuild-lookups",
              "optional": true,
              "when": "Studio lookup refresh is attempted"
            },
            {
              "id": "clean-generated-artifacts",
              "optional": true,
              "when": "published work artifacts or related generated records are cleaned"
            },
            {
              "id": "update-search",
              "optional": true,
              "when": "catalogue search rebuild is attempted"
            }
          ]
        },
        "delete-work": {
          "label": "delete work",
          "status": "v1-target",
          "control_id": "catalogueWorkDelete",
          "control_selector": "#catalogueWorkDelete",
          "control_label": "Delete",
          "endpoint": "/catalogue/delete-apply",
          "record_family": "work",
          "record_id_field": "work_id",
          "no_change_activity": "skip",
          "report_forced_rewrites": true,
          "notes": "Covers delete apply after the preview/confirmation flow, including dependent details and generated cleanup.",
          "script_purposes": [
            {
              "id": "delete-canonical-data",
              "optional": false,
              "when": "work source JSON and dependent source records are removed"
            },
            {
              "id": "clean-generated-artifacts",
              "optional": true,
              "when": "published artifacts, generated index records, or local media are cleaned"
            },
            {
              "id": "rebuild-lookups",
              "optional": true,
              "when": "Studio lookup refresh is attempted"
            },
            {
              "id": "update-search",
              "optional": true,
              "when": "catalogue search rebuild is attempted"
            }
          ]
        }
      }
    },
