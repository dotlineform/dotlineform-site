  "script_purposes": {
    "save-canonical-data": {
      "label": "save canonical data",
      "status": "v1-target",
      "artifact_families": ["source-json"],
      "detail_templates": [
        "Saved canonical work record {work_id}"
      ]
    },
    "delete-canonical-data": {
      "label": "delete canonical data",
      "status": "v1-target",
      "artifact_families": ["source-json"],
      "detail_templates": [
        "Deleted canonical source record {record_id}"
      ]
    },
    "clean-generated-artifacts": {
      "label": "clean generated artifacts",
      "status": "v1-target",
      "artifact_families": ["work-json", "series-json", "moment-json", "index-json", "local-media"],
      "detail_templates": [
        "Cleaned generated artifacts for {record_id}"
      ]
    },
    "rebuild-published-work-data": {
      "label": "rebuild published work data",
      "status": "v1-target",
      "artifact_families": ["work-json", "works-index-json", "series-index-json", "recent-index-json"],
      "detail_templates": [
        "Updated published work JSON for {work_id}"
      ]
    },
    "rebuild-published-series-data": {
      "label": "rebuild published series data",
      "status": "v1-target",
      "artifact_families": ["series-json", "work-json", "works-index-json", "series-index-json", "recent-index-json"],
      "detail_templates": [
        "Updated published series/work JSON for series {series_id}"
      ]
    },
    "rebuild-published-moment-data": {
      "label": "rebuild published moment data",
      "status": "v1-target",
      "artifact_families": ["moment-json", "moments-index-json"],
      "detail_templates": [
        "Updated published moment JSON for {moment_id}"
      ]
    },
    "rebuild-lookups": {
      "label": "rebuild lookups",
      "status": "v1-target",
      "artifact_families": ["studio-lookup"],
      "detail_templates": [
        "Refreshed catalogue lookup data for work {work_id}"
      ]
    },
    "update-search": {
      "label": "update search",
      "status": "v1-target",
      "artifact_families": ["catalogue-search"],
      "detail_templates": [
        "Rebuilt catalogue search for work {work_id}"
      ]
    }
  }
}
