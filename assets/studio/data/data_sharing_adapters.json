{
  "schema_version": "data_sharing_adapters_v2",
  "dispatch": [
    {
      "data_domain": "library",
      "operation": "prepare",
      "adapter_id": "documents"
    },
    {
      "data_domain": "library",
      "operation": "list_returned",
      "adapter_id": "documents"
    },
    {
      "data_domain": "library",
      "operation": "review",
      "adapter_id": "documents"
    },
    {
      "data_domain": "library",
      "operation": "apply",
      "adapter_id": "documents"
    },
    {
      "data_domain": "tags",
      "operation": "prepare",
      "adapter_id": "analytics-tags"
    },
    {
      "data_domain": "tags",
      "operation": "list_returned",
      "adapter_id": "analytics-tags"
    },
    {
      "data_domain": "tags",
      "operation": "review",
      "adapter_id": "analytics-tags"
    },
    {
      "data_domain": "tags",
      "operation": "apply",
      "adapter_id": "analytics-tags"
    }
  ],
  "adapters": [
    {
      "id": "documents",
      "module": "documents",
      "label": "Documents",
      "status": "active",
      "portability": {
        "package": "docs-viewer-documents-data-sharing"
      },
      "data_domains": {
        "library": {
          "label": "Library",
          "scope": "library",
          "status": "active",
          "selection_model": "documents",
          "paths": {
            "outbound_package_root": "var/studio/data-sharing/library/exports",
            "returned_package_staging_root": "var/studio/data-sharing/library/import-staging",
            "review_output_root": "var/studio/data-sharing/library/import-preview",
            "source_root": "_docs_library",
            "backup_root": "var/docs/backups"
          },
          "source_write_targets": {
            "documents": "_docs_library"
          },
          "sources": {
            "docs_index": "assets/data/docs/scopes/library/index.json",
            "docs_payload_root": "assets/data/docs/scopes/library/by-id",
            "source_root": "_docs_library"
          },
          "config": {
            "sharing_profiles_path": "assets/studio/data/library_export_configs.json"
          }
        }
      },
      "capabilities": [
        {
          "operation": "prepare",
          "status": "active",
          "selection_model": "documents",
          "input_formats": [],
          "output_formats": ["json", "jsonl"],
          "path_contract": {
            "output_root": "outbound_package_root"
          },
          "activity": {
            "script_purpose": "data-sharing-prepare",
            "record_groups": ["documents"]
          }
        },
        {
          "operation": "list_returned",
          "status": "active",
          "selection_model": "none",
          "input_formats": ["json", "jsonl"],
          "output_formats": [],
          "path_contract": {
            "staging_root": "returned_package_staging_root"
          },
          "activity": {
            "script_purpose": "data-sharing-list-returned",
            "record_groups": ["files"]
          }
        },
        {
          "operation": "review",
          "status": "active",
          "selection_model": "file_only",
          "input_formats": ["json", "jsonl"],
          "output_formats": ["markdown"],
          "path_contract": {
            "staging_root": "returned_package_staging_root",
            "review_output_root": "review_output_root"
          },
          "review_rows": {
            "fields": ["id", "type", "title", "meta", "record_index", "selectable", "record_groups", "issues"]
          },
          "activity": {
            "script_purpose": "data-sharing-review",
            "record_groups": ["documents", "files"]
          }
        },
        {
          "operation": "apply",
          "status": "active",
          "selection_model": "records",
          "input_formats": ["json", "jsonl"],
          "output_formats": [],
          "path_contract": {
            "staging_root": "returned_package_staging_root",
            "source_root": "source_root",
            "backup_root": "backup_root"
          },
          "requires_confirmation": true,
          "apply_actions": [
            {
              "id": "summary_apply",
              "label": "Update summaries",
              "status": "active",
              "ui": {
                "control_id": "dataSharingReviewUpdateSummary",
                "control_selector": "#dataSharingReviewUpdateSummary",
                "activity_action_id": "apply-returned-summaries",
                "selection_required_message": "Select at least one document preview.",
                "preflight_status": "Checking selected summaries...",
                "running_status": "Updating selected summaries...",
                "success_status": "Summaries updated.",
                "failed_status": "Summary update failed.",
                "cancelled_status": "Summary update cancelled.",
                "no_change_count_key": "updates"
              },
              "confirmation": {
                "title": "Update summaries?",
                "body": "This will back up and update selected Library source files.",
                "primary_label": "OK",
                "cancel_label": "Cancel"
              },
              "result": {
                "title": "Summary update complete",
                "count_text": "{updates} updates; {skipped} skipped; {errors} errors.",
                "count_rows": [
                  {
                    "key": "updates",
                    "label": "updates"
                  },
                  {
                    "key": "skipped",
                    "label": "skipped"
                  },
                  {
                    "key": "errors",
                    "label": "errors"
                  }
                ]
              },
              "activity": {
                "script_purpose": "data-sharing-apply",
                "record_groups": ["documents"]
              }
            },
            {
              "id": "hierarchy_apply",
              "label": "Apply hierarchy",
              "status": "active",
              "ui": {
                "control_id": "dataSharingReviewApplyHierarchy",
                "control_selector": "#dataSharingReviewApplyHierarchy",
                "activity_action_id": "apply-returned-hierarchy",
                "selection_required_message": "Select at least one document preview.",
                "preflight_status": "Checking selected hierarchy changes...",
                "running_status": "Updating selected hierarchy...",
                "success_status": "Hierarchy updated.",
                "failed_status": "Hierarchy update failed.",
                "cancelled_status": "Hierarchy update cancelled.",
                "no_change_count_key": "changed"
              },
              "confirmation": {
                "title": "Update hierarchy?",
                "body": "This will back up and update selected Library source parent ids.",
                "primary_label": "OK",
                "cancel_label": "Cancel"
              },
              "result": {
                "title": "Hierarchy update complete",
                "count_text": "{changed} changed; {unchanged} unchanged; {skipped} skipped; {warnings} warnings; {errors} errors.",
                "count_rows": [
                  {
                    "key": "changed",
                    "fallback_key": "updates",
                    "label": "changed"
                  },
                  {
                    "key": "unchanged",
                    "label": "unchanged"
                  },
                  {
                    "key": "skipped",
                    "label": "skipped"
                  },
                  {
                    "key": "warnings",
                    "label": "warnings"
                  },
                  {
                    "key": "errors",
                    "label": "errors"
                  }
                ]
              },
              "activity": {
                "script_purpose": "data-sharing-apply",
                "record_groups": ["documents"]
              }
            }
          ],
          "activity": {
            "script_purpose": "data-sharing-apply",
            "record_groups": ["documents"]
          }
        }
      ]
    },
    {
      "id": "analytics-tags",
      "module": "analytics.tags",
      "label": "Tags",
      "status": "stub",
      "portability": {
        "package": "analytics-tags-data-sharing"
      },
      "data_domains": {
        "tags": {
          "label": "Tags",
          "scope": "tags",
          "status": "stub",
          "selection_model": "records",
          "paths": {
            "outbound_package_root": "var/studio/data-sharing/tags/exports",
            "returned_package_staging_root": "var/studio/data-sharing/tags/import-staging",
            "review_output_root": "var/studio/data-sharing/tags/import-preview",
            "source_root": "assets/studio/data",
            "backup_root": "var/studio/data-sharing/tags/backups"
          },
          "source_write_targets": {
            "tag_registry": "assets/studio/data/tag_registry.json",
            "tag_aliases": "assets/studio/data/tag_aliases.json",
            "tag_assignments": "assets/studio/data/tag_assignments.json"
          },
          "sources": {
            "tag_registry": "assets/studio/data/tag_registry.json",
            "tag_aliases": "assets/studio/data/tag_aliases.json",
            "tag_assignments": "assets/studio/data/tag_assignments.json",
            "series": "assets/studio/data/catalogue/series.json",
            "works": "assets/studio/data/catalogue/works.json"
          },
          "config": {}
        }
      },
      "capabilities": [
        {
          "operation": "prepare",
          "status": "planned",
          "message": "Tags package preparation is not implemented yet.",
          "selection_model": "records",
          "input_formats": [],
          "output_formats": ["json"],
          "path_contract": {
            "output_root": "outbound_package_root"
          },
          "activity": {
            "script_purpose": "data-sharing-prepare",
            "record_groups": ["tags", "aliases", "series", "works", "files"]
          }
        },
        {
          "operation": "list_returned",
          "status": "planned",
          "message": "Tags returned package staging is not implemented yet.",
          "selection_model": "none",
          "input_formats": ["json", "jsonl"],
          "output_formats": [],
          "path_contract": {
            "staging_root": "returned_package_staging_root"
          },
          "activity": {
            "script_purpose": "data-sharing-list-returned",
            "record_groups": ["files"]
          }
        },
        {
          "operation": "review",
          "status": "planned",
          "message": "Tags returned package review is not implemented yet.",
          "selection_model": "file_only",
          "input_formats": ["json", "jsonl"],
          "output_formats": ["json"],
          "path_contract": {
            "staging_root": "returned_package_staging_root",
            "review_output_root": "review_output_root"
          },
          "review_rows": {
            "fields": ["id", "type", "title", "meta", "record_index", "selectable", "record_groups", "issues"]
          },
          "activity": {
            "script_purpose": "data-sharing-review",
            "record_groups": ["tags", "aliases", "series", "works", "files"]
          }
        },
        {
          "operation": "apply",
          "status": "planned",
          "message": "Tags apply is not implemented yet.",
          "selection_model": "records",
          "input_formats": ["json", "jsonl"],
          "output_formats": [],
          "path_contract": {
            "staging_root": "returned_package_staging_root",
            "source_root": "source_root",
            "backup_root": "backup_root"
          },
          "requires_confirmation": true,
          "apply_actions": [
            {
              "id": "registry_apply",
              "label": "Apply tag registry changes",
              "status": "planned",
              "confirmation": {
                "title": "Apply tag registry changes?",
                "body": "This will back up and update the Studio tag registry."
              },
              "activity": {
                "script_purpose": "data-sharing-apply",
                "record_groups": ["tags", "files"]
              }
            },
            {
              "id": "aliases_apply",
              "label": "Apply tag alias changes",
              "status": "planned",
              "confirmation": {
                "title": "Apply tag alias changes?",
                "body": "This will back up and update Studio tag aliases."
              },
              "activity": {
                "script_purpose": "data-sharing-apply",
                "record_groups": ["aliases", "tags", "files"]
              }
            },
            {
              "id": "assignments_apply",
              "label": "Apply tag assignment changes",
              "status": "planned",
              "confirmation": {
                "title": "Apply tag assignment changes?",
                "body": "This will back up and update Studio tag assignments."
              },
              "activity": {
                "script_purpose": "data-sharing-apply",
                "record_groups": ["series", "works", "tags", "files"]
              }
            }
          ],
          "activity": {
            "script_purpose": "data-sharing-apply",
            "record_groups": ["tags", "aliases", "series", "works", "files"]
          }
        }
      ]
    }
  ]
}
