#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

SITE_ENV_PATH="$ROOT_DIR/var/local/site.env"
if [ -f "$SITE_ENV_PATH" ]; then
  set -a
  # shellcheck source=/dev/null
  . "$SITE_ENV_PATH"
  set +a
fi

if [ -z "${SITE_PYTHON:-}" ]; then
  if [ -x "$HOME/miniconda3/bin/python3" ]; then
    SITE_PYTHON="$HOME/miniconda3/bin/python3"
  else
    SITE_PYTHON="python3"
  fi
fi

exec "$SITE_PYTHON" site-tools/site_validate.py "$@"
