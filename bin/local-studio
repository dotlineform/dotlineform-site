#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

SITE_ENV_PATH="$ROOT_DIR/var/local/site.env"
if [ -f "$SITE_ENV_PATH" ]; then
  set -a
  # shellcheck source=/dev/null
  . "$SITE_ENV_PATH"
  set +a
fi

if [ -x "$HOME/miniconda3/bin/python3" ]; then
  PYTHON_BIN="$HOME/miniconda3/bin/python3"
else
  PYTHON_BIN="${PYTHON_BIN:-python3}"
fi

STUDIO_APP_ENABLED="${STUDIO_APP_ENABLED:-1}"
STUDIO_APP_HOST="${STUDIO_APP_HOST:-127.0.0.1}"
STUDIO_APP_PORT="${STUDIO_APP_PORT:-8765}"
STUDIO_APP_ACCESS_LOG="${STUDIO_APP_ACCESS_LOG:-0}"
DOCS_WATCH_ENABLED="${DOCS_WATCH_ENABLED:-1}"
DOCS_WATCH_POLL_SECONDS="${DOCS_WATCH_POLL_SECONDS:-1.0}"
DOCS_WATCH_DEBOUNCE_SECONDS="${DOCS_WATCH_DEBOUNCE_SECONDS:-1.0}"
RUNNER_NAME="bin/local-studio"

STUDIO_APP_PID=""
DOCS_WATCHER_PID=""

port_available() {
  local host="$1"
  local port="$2"

  "$PYTHON_BIN" - "$host" "$port" <<'PY'
import socket
import sys

host = sys.argv[1]
port = int(sys.argv[2])
last_error = None

try:
    addrinfo = socket.getaddrinfo(
        host, port, type=socket.SOCK_STREAM, flags=socket.AI_PASSIVE
    )
except OSError as exc:
    print(exc, file=sys.stderr)
    raise SystemExit(1)

for family, socktype, proto, _canonname, sockaddr in addrinfo:
    sock = socket.socket(family, socktype, proto)
    try:
        sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        sock.bind(sockaddr)
        raise SystemExit(0)
    except OSError as exc:
        last_error = exc
    finally:
        sock.close()

if last_error is not None:
    print(last_error, file=sys.stderr)
raise SystemExit(1)
PY
}

require_open_port() {
  local service_name="$1"
  local host="$2"
  local port="$3"
  local env_name="$4"

  if port_available "$host" "$port"; then
    return 0
  fi

  echo "ERROR: $service_name cannot start on $host:$port because the port is unavailable." >&2
  echo "Set $env_name to a different port or stop the conflicting process, then rerun $RUNNER_NAME." >&2
  exit 1
}

cleanup() {
  trap - EXIT INT TERM
  if [ -n "$STUDIO_APP_PID" ] && kill -0 "$STUDIO_APP_PID" 2>/dev/null; then
    kill "$STUDIO_APP_PID" 2>/dev/null || true
  fi
  if [ -n "$DOCS_WATCHER_PID" ] && kill -0 "$DOCS_WATCHER_PID" 2>/dev/null; then
    kill "$DOCS_WATCHER_PID" 2>/dev/null || true
  fi
  if [ -n "$STUDIO_APP_PID" ]; then
    wait "$STUDIO_APP_PID" 2>/dev/null || true
  fi
  if [ -n "$DOCS_WATCHER_PID" ]; then
    wait "$DOCS_WATCHER_PID" 2>/dev/null || true
  fi
}

trap cleanup EXIT INT TERM

echo "Starting Local Studio from $ROOT_DIR"
if [ "$STUDIO_APP_ENABLED" != "0" ]; then
  echo "Local Studio App: http://$STUDIO_APP_HOST:$STUDIO_APP_PORT"
  case "$STUDIO_APP_ACCESS_LOG" in
    1|on|true|yes)
      echo "Local Studio App access log: enabled"
      ;;
    *)
      echo "Local Studio App access log: disabled"
      ;;
  esac
else
  echo "Local Studio App: disabled"
fi
echo "Catalogue APIs: handled by Local Studio App"
echo "Docs Viewer links/API: handled by configured Docs Viewer service (${DOCS_VIEWER_BASE_URL:-http://${DOCS_VIEWER_HOST:-127.0.0.1}:${DOCS_VIEWER_PORT:-8776}})"
echo "Audit/risk/activity/testing routes: handled by bin/local-admin"
echo "Analytics/tag/data-sharing routes: handled by bin/local-analytics"
if [ "$DOCS_WATCH_ENABLED" != "0" ]; then
  echo "Docs Live Watcher: enabled"
else
  echo "Docs Live Watcher: disabled"
fi
echo

if [ "$STUDIO_APP_ENABLED" != "0" ]; then
  require_open_port "Local Studio App" "$STUDIO_APP_HOST" "$STUDIO_APP_PORT" "STUDIO_APP_PORT"
fi

echo "Press Ctrl+C to stop all processes."
echo

if [ "$STUDIO_APP_ENABLED" != "0" ]; then
  STUDIO_APP_ARGS=(--host "$STUDIO_APP_HOST" --port "$STUDIO_APP_PORT")
  case "$STUDIO_APP_ACCESS_LOG" in
    1|on|true|yes)
      STUDIO_APP_ARGS+=(--access-log)
      ;;
  esac
  "$PYTHON_BIN" studio/app/server/studio/studio_app_server.py "${STUDIO_APP_ARGS[@]}" &
  STUDIO_APP_PID=$!
fi

if [ "$DOCS_WATCH_ENABLED" != "0" ]; then
  "$PYTHON_BIN" docs-viewer/services/docs_live_rebuild_watcher.py \
    --poll-seconds "$DOCS_WATCH_POLL_SECONDS" \
    --debounce-seconds "$DOCS_WATCH_DEBOUNCE_SECONDS" &
  DOCS_WATCHER_PID=$!
fi

if [ -z "$STUDIO_APP_PID" ] && [ -z "$DOCS_WATCHER_PID" ]; then
  echo "No long-running Local Studio processes are enabled; exiting."
  exit 0
fi

while true; do
  if [ -n "$STUDIO_APP_PID" ] && ! kill -0 "$STUDIO_APP_PID" 2>/dev/null; then
    wait "$STUDIO_APP_PID"
    break
  fi
  if [ -n "$DOCS_WATCHER_PID" ] && ! kill -0 "$DOCS_WATCHER_PID" 2>/dev/null; then
    wait "$DOCS_WATCHER_PID"
    break
  fi
  sleep 1
done
