#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

SITE_ENV_PATH="$ROOT_DIR/var/local/site.env"
if [ -f "$SITE_ENV_PATH" ]; then
  set -a
  # shellcheck source=/dev/null
  . "$SITE_ENV_PATH"
  set +a
fi

if [ -z "${PUBLIC_SITE_PYTHON:-}" ]; then
  if [ -x "$HOME/miniconda3/bin/python3" ]; then
    PUBLIC_SITE_PYTHON="$HOME/miniconda3/bin/python3"
  else
    PUBLIC_SITE_PYTHON="python3"
  fi
fi

PUBLIC_SITE_HOST="${PUBLIC_SITE_HOST:-127.0.0.1}"
PUBLIC_SITE_PORT="${PUBLIC_SITE_PORT:-4010}"
PUBLIC_SITE_DESTINATION="${PUBLIC_SITE_DESTINATION:-_public_site}"
PUBLIC_SITE_AUDIT="${PUBLIC_SITE_AUDIT:-1}"

EXTRA_BUILD_ARGS=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    --host)
      PUBLIC_SITE_HOST="$2"
      shift 2
      ;;
    --host=*)
      PUBLIC_SITE_HOST="${1#*=}"
      shift
      ;;
    --port)
      PUBLIC_SITE_PORT="$2"
      shift 2
      ;;
    --port=*)
      PUBLIC_SITE_PORT="${1#*=}"
      shift
      ;;
    --destination)
      PUBLIC_SITE_DESTINATION="$2"
      shift 2
      ;;
    --destination=*)
      PUBLIC_SITE_DESTINATION="${1#*=}"
      shift
      ;;
    --no-audit)
      PUBLIC_SITE_AUDIT=0
      shift
      ;;
    *)
      EXTRA_BUILD_ARGS+=("$1")
      shift
      ;;
  esac
done

BUILD_ARGS=(--destination "$PUBLIC_SITE_DESTINATION")
if [ "$PUBLIC_SITE_AUDIT" = "1" ]; then
  BUILD_ARGS+=(--audit)
fi
if [ "${#EXTRA_BUILD_ARGS[@]}" -gt 0 ]; then
  BUILD_ARGS+=("${EXTRA_BUILD_ARGS[@]}")
fi

"$PUBLIC_SITE_PYTHON" public-site/build/build_site.py "${BUILD_ARGS[@]}"

echo
echo "Starting static public-site preview from $ROOT_DIR/$PUBLIC_SITE_DESTINATION"
echo "Public site: http://$PUBLIC_SITE_HOST:$PUBLIC_SITE_PORT"
echo

exec "$PUBLIC_SITE_PYTHON" -m http.server "$PUBLIC_SITE_PORT" --bind "$PUBLIC_SITE_HOST" --directory "$PUBLIC_SITE_DESTINATION"
