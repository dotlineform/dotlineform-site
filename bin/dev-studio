#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

SITE_ENV_PATH="$ROOT_DIR/var/local/site.env"
if [ -f "$SITE_ENV_PATH" ]; then
  set -a
  # shellcheck source=/dev/null
  . "$SITE_ENV_PATH"
  set +a
fi

if [ -x "$HOME/.rbenv/shims/bundle" ]; then
  BUNDLE_BIN="$HOME/.rbenv/shims/bundle"
else
  BUNDLE_BIN="${BUNDLE_BIN:-bundle}"
fi

if [ -x "$HOME/miniconda3/bin/python3" ]; then
  PYTHON_BIN="$HOME/miniconda3/bin/python3"
else
  PYTHON_BIN="${PYTHON_BIN:-python3}"
fi

JEKYLL_HOST="${JEKYLL_HOST:-127.0.0.1}"
JEKYLL_PORT="${JEKYLL_PORT:-4000}"
JEKYLL_ENABLED="${JEKYLL_ENABLED:-1}"
if [ "${LOCAL_STUDIO_ONLY:-0}" != "0" ]; then
  JEKYLL_ENABLED=0
fi
STUDIO_APP_ENABLED="${STUDIO_APP_ENABLED:-1}"
STUDIO_APP_HOST="${STUDIO_APP_HOST:-127.0.0.1}"
STUDIO_APP_PORT="${STUDIO_APP_PORT:-8765}"
CATALOGUE_WRITE_PORT="${CATALOGUE_WRITE_PORT:-8788}"
CATALOGUE_WRITE_SERVER_ENABLED="${CATALOGUE_WRITE_SERVER_ENABLED:-0}"
AUDIT_SERVICE_PORT="${AUDIT_SERVICE_PORT:-8790}"
AUDIT_SERVICE_ENABLED="${AUDIT_SERVICE_ENABLED:-0}"
DOCS_STARTUP_REBUILD_SCOPES="${DOCS_STARTUP_REBUILD_SCOPES:-}"
CATALOGUE_STARTUP_LOOKUP_REBUILD="${CATALOGUE_STARTUP_LOOKUP_REBUILD:-off}"
DOCS_WATCH_ENABLED="${DOCS_WATCH_ENABLED:-1}"
DOCS_WATCH_POLL_SECONDS="${DOCS_WATCH_POLL_SECONDS:-1.0}"
DOCS_WATCH_DEBOUNCE_SECONDS="${DOCS_WATCH_DEBOUNCE_SECONDS:-1.0}"
DOTLINEFORM_BACKUP_RETENTION="${DOTLINEFORM_BACKUP_RETENTION:-on}"
JEKYLL_WEBRICK_FILTER="$ROOT_DIR/scripts/jekyll_webrick_client_reset_filter.rb"
JEKYLL_CONFIG="${JEKYLL_CONFIG:-_config.yml,_config.dev-studio.yml}"
JEKYLL_RUBYOPT="-r$JEKYLL_WEBRICK_FILTER"
if [ -n "${RUBYOPT:-}" ]; then
  JEKYLL_RUBYOPT="$JEKYLL_RUBYOPT $RUBYOPT"
fi
RUNNER_NAME="${RUNNER_NAME:-bin/dev-studio}"

JEKYLL_PID=""
STUDIO_APP_PID=""
CATALOGUE_WRITE_PID=""
AUDIT_SERVICE_PID=""
DOCS_WATCHER_PID=""
STARTUP_DOC_SCOPES=()
DOCS_SCOPE_IDS=()

load_docs_scope_ids() {
  local scope_id
  DOCS_SCOPE_IDS=()
  while IFS= read -r scope_id; do
    if [ -n "$scope_id" ]; then
      DOCS_SCOPE_IDS+=("$scope_id")
    fi
  done < <("$PYTHON_BIN" - <<'PY'
import json
from pathlib import Path

payload = json.loads(Path("scripts/docs/docs_scopes.json").read_text(encoding="utf-8"))
if payload.get("schema_version") != "docs_scopes_v1":
    raise SystemExit("Invalid docs scope config: expected docs_scopes_v1")
scopes = payload.get("scopes")
if not isinstance(scopes, list):
    raise SystemExit("Invalid docs scope config: expected scopes array")
for item in scopes:
    if isinstance(item, dict):
        scope_id = str(item.get("scope_id") or "").strip().lower()
        if scope_id:
            print(scope_id)
PY
)
  if [ "${#DOCS_SCOPE_IDS[@]}" -eq 0 ]; then
    echo "ERROR: No docs scopes found in scripts/docs/docs_scopes.json" >&2
    exit 1
  fi
}

docs_scope_supported() {
  local candidate="$1"
  local scope
  for scope in "${DOCS_SCOPE_IDS[@]}"; do
    if [ "$scope" = "$candidate" ]; then
      return 0
    fi
  done
  return 1
}

parse_startup_doc_scopes() {
  local raw="$1"
  local part
  local token
  local normalized
  local seen_scopes=" "

  STARTUP_DOC_SCOPES=()
  if [ -z "$raw" ]; then
    return 0
  fi

  IFS=',' read -r -a scope_parts <<< "$raw"
  for part in "${scope_parts[@]}"; do
    token="$(printf '%s' "$part" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
    normalized="$(printf '%s' "$token" | tr '[:upper:]' '[:lower:]')"
    if [ -z "$normalized" ]; then
      continue
    fi

    if ! docs_scope_supported "$normalized"; then
      echo "ERROR: Unsupported DOCS_STARTUP_REBUILD_SCOPES entry: $token" >&2
      echo "Use a comma-separated list of configured docs scopes: ${DOCS_SCOPE_IDS[*]}" >&2
      exit 1
    fi

    if [[ "$seen_scopes" != *" $normalized "* ]]; then
      STARTUP_DOC_SCOPES+=("$normalized")
      seen_scopes="$seen_scopes$normalized "
    fi
  done
}

port_available() {
  local host="$1"
  local port="$2"

  "$PYTHON_BIN" - "$host" "$port" <<'PY'
import socket
import sys

host = sys.argv[1]
port = int(sys.argv[2])
last_error = None

try:
    addrinfo = socket.getaddrinfo(
        host, port, type=socket.SOCK_STREAM, flags=socket.AI_PASSIVE
    )
except OSError as exc:
    print(exc, file=sys.stderr)
    raise SystemExit(1)

for family, socktype, proto, _canonname, sockaddr in addrinfo:
    sock = socket.socket(family, socktype, proto)
    try:
        sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        sock.bind(sockaddr)
        raise SystemExit(0)
    except OSError as exc:
        last_error = exc
    finally:
        sock.close()

if last_error is not None:
    print(last_error, file=sys.stderr)
raise SystemExit(1)
PY
}

require_open_port() {
  local service_name="$1"
  local host="$2"
  local port="$3"
  local env_name="$4"

  if port_available "$host" "$port"; then
    return 0
  fi

  echo "ERROR: $service_name cannot start on $host:$port because the port is unavailable." >&2
  if [ -n "$env_name" ]; then
    echo "Set $env_name to a different port or stop the conflicting process, then rerun $RUNNER_NAME." >&2
  else
    echo "Stop the conflicting process, then rerun $RUNNER_NAME." >&2
  fi
  exit 1
}

cleanup() {
  trap - EXIT INT TERM
  if [ -n "$JEKYLL_PID" ] && kill -0 "$JEKYLL_PID" 2>/dev/null; then
    kill "$JEKYLL_PID" 2>/dev/null || true
  fi
  if [ -n "$STUDIO_APP_PID" ] && kill -0 "$STUDIO_APP_PID" 2>/dev/null; then
    kill "$STUDIO_APP_PID" 2>/dev/null || true
  fi
  if [ -n "$CATALOGUE_WRITE_PID" ] && kill -0 "$CATALOGUE_WRITE_PID" 2>/dev/null; then
    kill "$CATALOGUE_WRITE_PID" 2>/dev/null || true
  fi
  if [ -n "$AUDIT_SERVICE_PID" ] && kill -0 "$AUDIT_SERVICE_PID" 2>/dev/null; then
    kill "$AUDIT_SERVICE_PID" 2>/dev/null || true
  fi
  if [ -n "$DOCS_WATCHER_PID" ] && kill -0 "$DOCS_WATCHER_PID" 2>/dev/null; then
    kill "$DOCS_WATCHER_PID" 2>/dev/null || true
  fi
  wait "$JEKYLL_PID" "$STUDIO_APP_PID" "$CATALOGUE_WRITE_PID" "$AUDIT_SERVICE_PID" "$DOCS_WATCHER_PID" 2>/dev/null || true
}

trap cleanup EXIT INT TERM

load_docs_scope_ids
parse_startup_doc_scopes "$DOCS_STARTUP_REBUILD_SCOPES"

echo "Starting Studio development services from $ROOT_DIR"
if [ "$JEKYLL_ENABLED" != "0" ]; then
  echo "Jekyll: http://$JEKYLL_HOST:$JEKYLL_PORT"
  echo "Jekyll config: $JEKYLL_CONFIG"
else
  echo "Jekyll: disabled"
fi
if [ "$STUDIO_APP_ENABLED" != "0" ]; then
  echo "Local Studio App: http://$STUDIO_APP_HOST:$STUDIO_APP_PORT"
else
  echo "Local Studio App: disabled"
fi
if [ "$CATALOGUE_WRITE_SERVER_ENABLED" != "0" ]; then
  echo "Catalogue Write Server: http://127.0.0.1:$CATALOGUE_WRITE_PORT"
else
  echo "Catalogue Write Server: disabled (handled by Local Studio App)"
fi
echo "Docs management API: handled by Local Studio App"
if [ "$AUDIT_SERVICE_ENABLED" != "0" ]; then
  echo "Audit Service: http://127.0.0.1:$AUDIT_SERVICE_PORT"
else
  echo "Audit Service: disabled (handled by Local Studio App)"
fi
if [ "$STUDIO_APP_ENABLED" != "0" ]; then
  echo "Series Tag Editor: http://$STUDIO_APP_HOST:$STUDIO_APP_PORT/studio/analytics/series-tag-editor/?series=<series_id>"
fi
if [ "${#STARTUP_DOC_SCOPES[@]}" -gt 0 ]; then
  echo "Startup docs rebuild scopes: ${STARTUP_DOC_SCOPES[*]}"
else
  echo "Startup docs rebuild scopes: none"
fi
case "$CATALOGUE_STARTUP_LOOKUP_REBUILD" in
  1|on|true|yes)
    echo "Startup catalogue lookup rebuild: enabled"
    ;;
  *)
    echo "Startup catalogue lookup rebuild: disabled"
    ;;
esac
if [ "$DOCS_WATCH_ENABLED" != "0" ]; then
  echo "Docs Live Watcher: enabled (configured docs scopes: ${DOCS_SCOPE_IDS[*]})"
else
  echo "Docs Live Watcher: disabled"
fi
if [ "$DOTLINEFORM_BACKUP_RETENTION" = "off" ] || [ "$DOTLINEFORM_BACKUP_RETENTION" = "0" ]; then
  echo "Backup retention: disabled"
else
  echo "Backup retention: enabled"
fi
echo

if [ "$JEKYLL_ENABLED" != "0" ]; then
  require_open_port "Jekyll" "$JEKYLL_HOST" "$JEKYLL_PORT" "JEKYLL_PORT"
fi
if [ "$STUDIO_APP_ENABLED" != "0" ]; then
  require_open_port "Local Studio App" "$STUDIO_APP_HOST" "$STUDIO_APP_PORT" "STUDIO_APP_PORT"
fi
if [ "$CATALOGUE_WRITE_SERVER_ENABLED" != "0" ]; then
  require_open_port "Catalogue Write Server" "127.0.0.1" "$CATALOGUE_WRITE_PORT" "CATALOGUE_WRITE_PORT"
fi
if [ "$AUDIT_SERVICE_ENABLED" != "0" ]; then
  require_open_port "Audit Service" "127.0.0.1" "$AUDIT_SERVICE_PORT" "AUDIT_SERVICE_PORT"
fi

if [ "$DOTLINEFORM_BACKUP_RETENTION" = "off" ] || [ "$DOTLINEFORM_BACKUP_RETENTION" = "0" ]; then
  echo "Skipping Studio backup retention cleanup"
else
  "$PYTHON_BIN" scripts/studio/studio_backup_retention.py --write --quiet || {
    echo "WARNING: Studio backup retention cleanup failed; continuing startup." >&2
  }
fi

if [ "${#STARTUP_DOC_SCOPES[@]}" -eq 0 ]; then
  echo "Skipping startup docs/docs-search rebuilds"
else
  for scope in "${STARTUP_DOC_SCOPES[@]}"; do
    echo "Building docs viewer data for scope: $scope"
    "$BUNDLE_BIN" exec ruby scripts/build_docs.rb --scope "$scope" --write
    echo "Building docs search data for scope: $scope"
    "$BUNDLE_BIN" exec ruby scripts/build_search.rb --scope "$scope" --write
  done
fi
case "$CATALOGUE_STARTUP_LOOKUP_REBUILD" in
  1|on|true|yes)
    echo "Building catalogue lookup data"
    "$PYTHON_BIN" scripts/catalogue/export_catalogue_lookup.py --write
    ;;
  *)
    echo "Skipping startup catalogue lookup rebuild"
    ;;
esac
echo
echo "Press Ctrl+C to stop all processes."
echo

if [ "$JEKYLL_ENABLED" != "0" ]; then
  RUBYOPT="$JEKYLL_RUBYOPT" "$BUNDLE_BIN" exec jekyll serve --config "$JEKYLL_CONFIG" --host "$JEKYLL_HOST" --port "$JEKYLL_PORT" &
  JEKYLL_PID=$!
fi

if [ "$STUDIO_APP_ENABLED" != "0" ]; then
  "$PYTHON_BIN" scripts/studio/studio_app_server.py --host "$STUDIO_APP_HOST" --port "$STUDIO_APP_PORT" &
  STUDIO_APP_PID=$!
fi

if [ "$CATALOGUE_WRITE_SERVER_ENABLED" != "0" ]; then
  "$PYTHON_BIN" scripts/catalogue/catalogue_write_server.py --port "$CATALOGUE_WRITE_PORT" &
  CATALOGUE_WRITE_PID=$!
fi

if [ "$AUDIT_SERVICE_ENABLED" != "0" ]; then
  "$PYTHON_BIN" scripts/studio/audit_service.py --port "$AUDIT_SERVICE_PORT" &
  AUDIT_SERVICE_PID=$!
fi

if [ "$DOCS_WATCH_ENABLED" != "0" ]; then
  "$PYTHON_BIN" scripts/docs/docs_live_rebuild_watcher.py \
    --poll-seconds "$DOCS_WATCH_POLL_SECONDS" \
    --debounce-seconds "$DOCS_WATCH_DEBOUNCE_SECONDS" &
  DOCS_WATCHER_PID=$!
fi

while true; do
  if [ -n "$JEKYLL_PID" ] && ! kill -0 "$JEKYLL_PID" 2>/dev/null; then
    wait "$JEKYLL_PID"
    break
  fi
  if [ -n "$STUDIO_APP_PID" ] && ! kill -0 "$STUDIO_APP_PID" 2>/dev/null; then
    wait "$STUDIO_APP_PID"
    break
  fi
  if [ -n "$CATALOGUE_WRITE_PID" ] && ! kill -0 "$CATALOGUE_WRITE_PID" 2>/dev/null; then
    wait "$CATALOGUE_WRITE_PID"
    break
  fi
  if [ -n "$AUDIT_SERVICE_PID" ] && ! kill -0 "$AUDIT_SERVICE_PID" 2>/dev/null; then
    wait "$AUDIT_SERVICE_PID"
    break
  fi
  if [ -n "$DOCS_WATCHER_PID" ] && ! kill -0 "$DOCS_WATCHER_PID" 2>/dev/null; then
    wait "$DOCS_WATCHER_PID"
    break
  fi
  sleep 1
done
