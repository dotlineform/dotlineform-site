#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

if [ -x "$HOME/.rbenv/shims/bundle" ]; then
  BUNDLE_BIN="$HOME/.rbenv/shims/bundle"
else
  BUNDLE_BIN="${BUNDLE_BIN:-bundle}"
fi

if [ -x "$HOME/miniconda3/bin/python3" ]; then
  PYTHON_BIN="$HOME/miniconda3/bin/python3"
else
  PYTHON_BIN="${PYTHON_BIN:-python3}"
fi

JEKYLL_HOST="${JEKYLL_HOST:-127.0.0.1}"
JEKYLL_PORT="${JEKYLL_PORT:-4000}"
TAG_WRITE_PORT="${TAG_WRITE_PORT:-8787}"
CATALOGUE_WRITE_PORT="${CATALOGUE_WRITE_PORT:-8788}"
DOCS_MANAGEMENT_PORT="${DOCS_MANAGEMENT_PORT:-8789}"
DOCS_STARTUP_REBUILD_SCOPES="${DOCS_STARTUP_REBUILD_SCOPES:-}"
DOCS_WATCH_ENABLED="${DOCS_WATCH_ENABLED:-1}"
DOCS_WATCH_POLL_SECONDS="${DOCS_WATCH_POLL_SECONDS:-1.0}"
DOCS_WATCH_DEBOUNCE_SECONDS="${DOCS_WATCH_DEBOUNCE_SECONDS:-1.0}"
JEKYLL_WEBRICK_FILTER="$ROOT_DIR/scripts/jekyll_webrick_client_reset_filter.rb"
JEKYLL_RUBYOPT="-r$JEKYLL_WEBRICK_FILTER"
if [ -n "${RUBYOPT:-}" ]; then
  JEKYLL_RUBYOPT="$JEKYLL_RUBYOPT $RUBYOPT"
fi

JEKYLL_PID=""
TAG_WRITE_PID=""
CATALOGUE_WRITE_PID=""
DOCS_MANAGEMENT_PID=""
DOCS_WATCHER_PID=""
STARTUP_DOC_SCOPES=()

parse_startup_doc_scopes() {
  local raw="$1"
  local part
  local token
  local normalized
  local seen_scopes=" "

  STARTUP_DOC_SCOPES=()
  if [ -z "$raw" ]; then
    return 0
  fi

  IFS=',' read -r -a scope_parts <<< "$raw"
  for part in "${scope_parts[@]}"; do
    token="$(printf '%s' "$part" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
    normalized="$(printf '%s' "$token" | tr '[:upper:]' '[:lower:]')"
    if [ -z "$normalized" ]; then
      continue
    fi

    case "$normalized" in
      studio|library)
        if [[ "$seen_scopes" != *" $normalized "* ]]; then
          STARTUP_DOC_SCOPES+=("$normalized")
          seen_scopes="$seen_scopes$normalized "
        fi
        ;;
      *)
        echo "ERROR: Unsupported DOCS_STARTUP_REBUILD_SCOPES entry: $token" >&2
        echo "Use a comma-separated list of: studio, library" >&2
        exit 1
        ;;
    esac
  done
}

port_available() {
  local host="$1"
  local port="$2"

  "$PYTHON_BIN" - "$host" "$port" <<'PY'
import socket
import sys

host = sys.argv[1]
port = int(sys.argv[2])
last_error = None

try:
    addrinfo = socket.getaddrinfo(
        host, port, type=socket.SOCK_STREAM, flags=socket.AI_PASSIVE
    )
except OSError as exc:
    print(exc, file=sys.stderr)
    raise SystemExit(1)

for family, socktype, proto, _canonname, sockaddr in addrinfo:
    sock = socket.socket(family, socktype, proto)
    try:
        sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        sock.bind(sockaddr)
        raise SystemExit(0)
    except OSError as exc:
        last_error = exc
    finally:
        sock.close()

if last_error is not None:
    print(last_error, file=sys.stderr)
raise SystemExit(1)
PY
}

require_open_port() {
  local service_name="$1"
  local host="$2"
  local port="$3"
  local env_name="$4"

  if port_available "$host" "$port"; then
    return 0
  fi

  echo "ERROR: $service_name cannot start on $host:$port because the port is unavailable." >&2
  if [ -n "$env_name" ]; then
    echo "Set $env_name to a different port or stop the conflicting process, then rerun bin/dev-studio." >&2
  else
    echo "Stop the conflicting process, then rerun bin/dev-studio." >&2
  fi
  exit 1
}

cleanup() {
  trap - EXIT INT TERM
  if [ -n "$JEKYLL_PID" ] && kill -0 "$JEKYLL_PID" 2>/dev/null; then
    kill "$JEKYLL_PID" 2>/dev/null || true
  fi
  if [ -n "$TAG_WRITE_PID" ] && kill -0 "$TAG_WRITE_PID" 2>/dev/null; then
    kill "$TAG_WRITE_PID" 2>/dev/null || true
  fi
  if [ -n "$CATALOGUE_WRITE_PID" ] && kill -0 "$CATALOGUE_WRITE_PID" 2>/dev/null; then
    kill "$CATALOGUE_WRITE_PID" 2>/dev/null || true
  fi
  if [ -n "$DOCS_MANAGEMENT_PID" ] && kill -0 "$DOCS_MANAGEMENT_PID" 2>/dev/null; then
    kill "$DOCS_MANAGEMENT_PID" 2>/dev/null || true
  fi
  if [ -n "$DOCS_WATCHER_PID" ] && kill -0 "$DOCS_WATCHER_PID" 2>/dev/null; then
    kill "$DOCS_WATCHER_PID" 2>/dev/null || true
  fi
  wait "$JEKYLL_PID" "$TAG_WRITE_PID" "$CATALOGUE_WRITE_PID" "$DOCS_MANAGEMENT_PID" "$DOCS_WATCHER_PID" 2>/dev/null || true
}

trap cleanup EXIT INT TERM

parse_startup_doc_scopes "$DOCS_STARTUP_REBUILD_SCOPES"

echo "Starting Studio development services from $ROOT_DIR"
echo "Jekyll: http://$JEKYLL_HOST:$JEKYLL_PORT"
echo "Tag Write Server: http://127.0.0.1:$TAG_WRITE_PORT"
echo "Catalogue Write Server: http://127.0.0.1:$CATALOGUE_WRITE_PORT"
echo "Docs Management Server: http://127.0.0.1:$DOCS_MANAGEMENT_PORT"
echo "Series Tag Editor: http://$JEKYLL_HOST:$JEKYLL_PORT/studio/series-tag-editor/?series=<series_id>"
if [ "${#STARTUP_DOC_SCOPES[@]}" -gt 0 ]; then
  echo "Startup docs rebuild scopes: ${STARTUP_DOC_SCOPES[*]}"
else
  echo "Startup docs rebuild scopes: none"
fi
if [ "$DOCS_WATCH_ENABLED" != "0" ]; then
  echo "Docs Live Watcher: enabled (_docs_src + _docs_library_src)"
else
  echo "Docs Live Watcher: disabled"
fi
echo

require_open_port "Jekyll" "$JEKYLL_HOST" "$JEKYLL_PORT" "JEKYLL_PORT"
require_open_port "Tag Write Server" "127.0.0.1" "$TAG_WRITE_PORT" "TAG_WRITE_PORT"
require_open_port "Catalogue Write Server" "127.0.0.1" "$CATALOGUE_WRITE_PORT" "CATALOGUE_WRITE_PORT"
require_open_port "Docs Management Server" "127.0.0.1" "$DOCS_MANAGEMENT_PORT" "DOCS_MANAGEMENT_PORT"

if [ "${#STARTUP_DOC_SCOPES[@]}" -eq 0 ]; then
  echo "Skipping startup docs/docs-search rebuilds"
else
  for scope in "${STARTUP_DOC_SCOPES[@]}"; do
    if [ "$scope" = "studio" ]; then
      scope_label="Studio"
    else
      scope_label="Library"
    fi
    echo "Building $scope_label docs viewer data"
    "$BUNDLE_BIN" exec ruby scripts/build_docs.rb --scope "$scope" --write
    echo "Building $scope_label docs search data"
    "$BUNDLE_BIN" exec ruby scripts/build_search.rb --scope "$scope" --write
  done
fi
echo "Building catalogue lookup data"
"$PYTHON_BIN" scripts/export_catalogue_lookup.py --write
echo
echo "Press Ctrl+C to stop all processes."
echo

RUBYOPT="$JEKYLL_RUBYOPT" "$BUNDLE_BIN" exec jekyll serve --host "$JEKYLL_HOST" --port "$JEKYLL_PORT" &
JEKYLL_PID=$!

"$PYTHON_BIN" scripts/studio/tag_write_server.py --port "$TAG_WRITE_PORT" &
TAG_WRITE_PID=$!

"$PYTHON_BIN" scripts/studio/catalogue_write_server.py --port "$CATALOGUE_WRITE_PORT" &
CATALOGUE_WRITE_PID=$!

"$PYTHON_BIN" scripts/docs/docs_management_server.py --port "$DOCS_MANAGEMENT_PORT" &
DOCS_MANAGEMENT_PID=$!

if [ "$DOCS_WATCH_ENABLED" != "0" ]; then
  "$PYTHON_BIN" scripts/docs/docs_live_rebuild_watcher.py \
    --poll-seconds "$DOCS_WATCH_POLL_SECONDS" \
    --debounce-seconds "$DOCS_WATCH_DEBOUNCE_SECONDS" &
  DOCS_WATCHER_PID=$!
fi

while true; do
  if ! kill -0 "$JEKYLL_PID" 2>/dev/null; then
    wait "$JEKYLL_PID"
    break
  fi
  if ! kill -0 "$TAG_WRITE_PID" 2>/dev/null; then
    wait "$TAG_WRITE_PID"
    break
  fi
  if ! kill -0 "$CATALOGUE_WRITE_PID" 2>/dev/null; then
    wait "$CATALOGUE_WRITE_PID"
    break
  fi
  if ! kill -0 "$DOCS_MANAGEMENT_PID" 2>/dev/null; then
    wait "$DOCS_MANAGEMENT_PID"
    break
  fi
  if [ -n "$DOCS_WATCHER_PID" ] && ! kill -0 "$DOCS_WATCHER_PID" 2>/dev/null; then
    wait "$DOCS_WATCHER_PID"
    break
  fi
  sleep 1
done
