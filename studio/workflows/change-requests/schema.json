{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dotlineform.local/schemas/docs-log-entry.schema.json",
  "title": "Docs Log Entry",
  "description": "One structured project change-history entry stored as a per-entry JSON file under studio/workflows/change-requests/logs/entries/.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "date",
    "title",
    "status",
    "type",
    "domains",
    "summary",
    "source"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^change-[0-9]{4}-[0-9]{2}-[0-9]{2}-[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Stable entry id generated from the change date and title."
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Change date in YYYY-MM-DD form."
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "implemented",
        "completed",
        "in-progress",
        "proposed",
        "decided",
        "superseded",
        "archived",
        "unknown"
      ]
    },
    "type": {
      "type": "string",
      "enum": [
        "implementation",
        "bugfix",
        "cleanup",
        "refactor",
        "documentation",
        "request",
        "decision",
        "verification",
        "migration",
        "maintenance",
        "other"
      ]
    },
    "domains": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "description": "Machine-readable domains such as docs-viewer, catalogue, search, library, studio-ui, build, scripts, data-models, or runtime."
    },
    "subjects": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "change_request_doc_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Optional _docs change request doc_id when this log entry implements or closes a request."
    },
    "related_docs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "default": []
    },
    "related_files": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "Short factual summary of the change."
    },
    "effect": {
      "type": "string",
      "description": "Why the change matters or what behavior it changes."
    },
    "area": {
      "type": "string",
      "description": "Legacy changelog area text when present."
    },
    "affected": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "files": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "docs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Verification notes or command summaries when captured in the original entry."
    },
    "body": {
      "type": "string",
      "description": "Optional preserved prose when the migration cannot confidently split the entry into structured fields."
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "file"
      ],
      "properties": {
        "file": {
          "type": "string",
          "minLength": 1
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "archive": {
          "type": "string",
          "description": "Source archive bucket or label, such as current, 2026-05, 2026-04, or search."
        }
      }
    },
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      }
    }
  }
}
