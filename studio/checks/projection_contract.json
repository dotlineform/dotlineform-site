{
  "schema_version": "projection_contract_v1",
  "artifact_families": [
    {
      "id": "catalogue_canonical_source",
      "classification": "canonical_source",
      "repo_paths": [
        "studio/data/canonical/catalogue/*.json",
        "studio/data/canonical/catalogue-markdown/**"
      ],
      "public_output": {
        "policy": "forbidden",
        "paths": [
          "studio/data/canonical/catalogue",
          "studio/data/canonical/catalogue-markdown"
        ]
      },
      "jekyll_exclude_required": true,
      "owner_doc": "data-models-catalogue-source"
    },
    {
      "id": "catalogue_public_route_stubs",
      "classification": "public_projection",
      "repo_paths": [
        "_works/*.md",
        "_series/*.md",
        "_work_details/*.md",
        "_moments/*.md"
      ],
      "public_output": {
        "policy": "allowed",
        "paths": [
          "works/*/index.html",
          "series/*/index.html",
          "work_details/*/index.html",
          "moments/*/index.html"
        ]
      },
      "owner_doc": "data-models-catalogue-source"
    },
    {
      "id": "catalogue_public_indexes",
      "classification": "public_projection",
      "repo_paths": [
        "assets/data/works_index.json",
        "assets/data/series_index.json",
        "assets/data/moments_index.json",
        "assets/data/recent_index.json"
      ],
      "public_output": {
        "policy": "required",
        "paths": [
          "assets/data/works_index.json",
          "assets/data/series_index.json",
          "assets/data/moments_index.json",
          "assets/data/recent_index.json"
        ]
      },
      "owner_doc": "data-models-catalogue-indexes"
    },
    {
      "id": "catalogue_public_record_payloads",
      "classification": "public_projection",
      "repo_paths": [
        "assets/works/index/*.json",
        "assets/series/index/*.json",
        "assets/moments/index/*.json"
      ],
      "public_output": {
        "policy": "required",
        "paths": [
          "assets/works/index/*.json",
          "assets/series/index/*.json",
          "assets/moments/index/*.json"
        ]
      },
      "owner_doc": "data-models-catalogue-indexes"
    },
    {
      "id": "catalogue_public_search",
      "classification": "public_projection",
      "repo_paths": [
        "assets/data/search/catalogue/index.json"
      ],
      "public_output": {
        "policy": "required",
        "paths": [
          "assets/data/search/catalogue/index.json"
        ]
      },
      "owner_doc": "search-build-pipeline-catalogue"
    },
    {
      "id": "catalogue_studio_lookup_projections",
      "classification": "studio_projection",
      "repo_paths": [
        "studio/data/generated/catalogue-lookup/**",
        "studio/data/config/catalogue/catalogue-field-registry.json",
        "studio/data/generated/activity/work-storage-index.json"
      ],
      "public_output": {
        "policy": "forbidden",
        "paths": [
          "studio/data/generated/catalogue-lookup",
          "studio/data/config/catalogue/catalogue-field-registry.json",
          "studio/data/generated/activity/work-storage-index.json"
        ]
      },
      "jekyll_exclude_required": true,
      "owner_doc": "data-models-catalogue"
    },
    {
      "id": "analytics_tag_source_data",
      "classification": "canonical_source",
      "repo_paths": [
        "analytics-app/data/canonical/tag-registry.json",
        "analytics-app/data/canonical/tag-aliases.json",
        "analytics-app/data/canonical/tag-assignments.json",
        "analytics-app/data/canonical/tag-groups.json"
      ],
      "public_output": {
        "policy": "forbidden",
        "paths": [
          "analytics-app/data/canonical/tag-registry.json",
          "analytics-app/data/canonical/tag-aliases.json",
          "analytics-app/data/canonical/tag-assignments.json",
          "analytics-app/data/canonical/tag-groups.json"
        ]
      },
      "jekyll_exclude_required": true,
      "owner_doc": "analytics"
    },
    {
      "id": "studio_config_and_ui_text",
      "classification": "studio_projection",
      "repo_paths": [
        "studio/app/frontend/config/studio-config.json",
        "studio/app/frontend/config/ui-text/*.json",
        "studio/data/config/runtime/activity-contract.json"
      ],
      "public_output": {
        "policy": "forbidden",
        "paths": [
          "studio/app/frontend/config/studio-config.json",
          "studio/app/frontend/config/ui-text",
          "studio/data/config/runtime/activity-contract.json"
        ]
      },
      "jekyll_exclude_required": true,
      "owner_doc": "config-studio-config-json"
    },
    {
      "id": "studio_docs_source",
      "classification": "canonical_source",
      "repo_paths": [
        "docs-viewer/source/studio/*.md"
      ],
      "public_output": {
        "policy": "forbidden",
        "paths": [
          "docs-viewer/source/studio"
        ]
      },
      "jekyll_exclude_required": true,
      "owner_doc": "data-models-studio"
    },
    {
      "id": "studio_docs_payloads",
      "classification": "docs_viewer_payload",
      "repo_paths": [
        "docs-viewer/generated/docs/studio/index.json",
        "docs-viewer/generated/docs/studio/by-id/*.json",
        "docs-viewer/generated/docs/studio/references/**"
      ],
      "public_output": {
        "policy": "forbidden",
        "paths": [
          "docs-viewer/generated/docs/studio"
        ]
      },
      "jekyll_exclude_required": true,
      "owner_doc": "data-models-studio"
    },
    {
      "id": "studio_docs_search",
      "classification": "docs_viewer_payload",
      "repo_paths": [
        "docs-viewer/generated/search/studio/index.json"
      ],
      "public_output": {
        "policy": "forbidden",
        "paths": [
          "docs-viewer/generated/search/studio"
        ]
      },
      "jekyll_exclude_required": true,
      "owner_doc": "search-build-pipeline-studio"
    },
    {
      "id": "library_docs_source",
      "classification": "canonical_source",
      "repo_paths": [
        "docs-viewer/source/library/*.md"
      ],
      "public_output": {
        "policy": "forbidden",
        "paths": [
          "docs-viewer/source/library"
        ]
      },
      "jekyll_exclude_required": true,
      "owner_doc": "data-models-library"
    },
    {
      "id": "library_docs_payloads",
      "classification": "docs_viewer_payload",
      "repo_paths": [
        "assets/data/docs/scopes/library/index.json",
        "assets/data/docs/scopes/library/by-id/*.json"
      ],
      "public_output": {
        "policy": "required",
        "paths": [
          "assets/data/docs/scopes/library/index.json",
          "assets/data/docs/scopes/library/by-id/*.json"
        ]
      },
      "owner_doc": "data-models-library"
    },
    {
      "id": "library_docs_search",
      "classification": "docs_viewer_payload",
      "repo_paths": [
        "assets/data/search/library/index.json"
      ],
      "public_output": {
        "policy": "required",
        "paths": [
          "assets/data/search/library/index.json"
        ]
      },
      "owner_doc": "search-build-pipeline-library"
    },
    {
      "id": "analysis_docs_source",
      "classification": "canonical_source",
      "repo_paths": [
        "docs-viewer/source/analysis/**/*.md"
      ],
      "public_output": {
        "policy": "forbidden",
        "paths": [
          "docs-viewer/source/analysis"
        ]
      },
      "jekyll_exclude_required": true,
      "owner_doc": "data-models-analysis"
    },
    {
      "id": "analysis_docs_payloads",
      "classification": "docs_viewer_payload",
      "repo_paths": [
        "assets/data/docs/scopes/analysis/index.json",
        "assets/data/docs/scopes/analysis/by-id/*.json",
        "assets/data/docs/scopes/analysis/references/**"
      ],
      "public_output": {
        "policy": "required",
        "paths": [
          "assets/data/docs/scopes/analysis/index.json",
          "assets/data/docs/scopes/analysis/by-id/*.json"
        ]
      },
      "owner_doc": "data-models-analysis"
    },
    {
      "id": "analysis_docs_search",
      "classification": "docs_viewer_payload",
      "repo_paths": [
        "assets/data/search/analysis/index.json"
      ],
      "public_output": {
        "policy": "required",
        "paths": [
          "assets/data/search/analysis/index.json"
        ]
      },
      "owner_doc": "search-build-pipeline-analysis"
    },
    {
      "id": "docs_viewer_runtime",
      "classification": "public_runtime_asset",
      "repo_paths": [
        "docs-viewer/runtime/js/*.js",
        "docs-viewer/static/css/*.css",
        "docs-viewer/config/ui-text/ui-text.json",
        "docs-viewer/config/defaults/docs-viewer-public-config.json"
      ],
      "public_output": {
        "policy": "required",
        "paths": [
          "docs-viewer/runtime/js/docs-viewer.js",
          "docs-viewer/static/css/docs-viewer.css",
          "docs-viewer/config/defaults/docs-viewer-public-config.json"
        ]
      },
      "owner_doc": "docs-viewer-runtime-boundary"
    },
    {
      "id": "docs_viewer_management_runtime",
      "classification": "studio_projection",
      "repo_paths": [
        "docs-viewer/runtime/js/docs-viewer-management*.js",
        "docs-viewer/runtime/js/docs-html-import*.js",
        "docs-viewer/static/css/docs-viewer-management.css",
        "docs-viewer/config/defaults/docs-viewer-config.json"
      ],
      "public_output": {
        "policy": "allowed",
        "paths": [
          "docs-viewer/runtime/js/docs-viewer-management*.js",
          "docs-viewer/runtime/js/docs-html-import*.js",
          "docs-viewer/static/css/docs-viewer-management.css",
          "docs-viewer/config/defaults/docs-viewer-config.json"
        ]
      },
      "owner_doc": "docs-viewer-management"
    },
    {
      "id": "public_search_policy",
      "classification": "public_projection",
      "repo_paths": [
        "assets/data/search/policy.json"
      ],
      "public_output": {
        "policy": "required",
        "paths": [
          "assets/data/search/policy.json"
        ]
      },
      "owner_doc": "search-public-ui-contract"
    },
    {
      "id": "public_media_and_thumbnails",
      "classification": "public_runtime_asset",
      "repo_paths": [
        "assets/works/img/**",
        "assets/work_details/img/**",
        "assets/moments/img/**",
        "assets/docs/**"
      ],
      "public_output": {
        "policy": "allowed",
        "paths": [
          "assets/works/img/**",
          "assets/work_details/img/**",
          "assets/moments/img/**",
          "assets/docs/**"
        ]
      },
      "owner_doc": "scripts-build-catalogue-json"
    },
    {
      "id": "studio_app_assets",
      "classification": "studio_app_asset",
      "repo_paths": [
        "studio/app/assets/css/**",
        "studio/app/frontend/js/**",
        "studio/data/**"
      ],
      "public_output": {
        "policy": "forbidden",
        "paths": [
          "assets/studio"
        ]
      },
      "jekyll_exclude_required": true,
      "owner_doc": "local-studio-app-public-surface"
    },
    {
      "id": "analytics_app_assets",
      "classification": "analytics_app_asset",
      "repo_paths": [
        "analytics-app/**"
      ],
      "public_output": {
        "policy": "forbidden",
        "paths": [
          "analytics-app"
        ]
      },
      "jekyll_exclude_required": true,
      "owner_doc": "local-studio-app"
    },
    {
      "id": "ui_catalogue_demo_assets",
      "classification": "ui_catalogue_app_asset",
      "repo_paths": [
        "ui-catalogue-app/**"
      ],
      "public_output": {
        "policy": "forbidden",
        "paths": [
          "ui-catalogue-app",
          "studio/ui-catalogue",
          "assets/ui-catalogue",
          "assets/docs/ui-catalogue",
          "_ui_catalogue_notes",
          "_includes/ui_catalogue_notes"
        ]
      },
      "jekyll_exclude_required": true,
      "owner_doc": "ui-catalogue"
    },
    {
      "id": "local_working_output",
      "classification": "local_working_output",
      "repo_paths": [
        "var/**",
        "logs/**"
      ],
      "public_output": {
        "policy": "forbidden",
        "paths": [
          "var",
          "logs"
        ]
      },
      "jekyll_exclude_required": true,
      "owner_doc": "local-setup"
    }
  ],
  "field_leak_rules": [
    {
      "id": "catalogue_source_media_paths",
      "description": "Source media path fields can stay in canonical catalogue source but must not appear in public JSON or search projections.",
      "fields": [
        "project_folder",
        "project_subfolder",
        "project_filename",
        "details_subfolder",
        "source_image_file",
        "provenance",
        "storage",
        "notes"
      ],
      "public_paths": [
        "assets/data/works_index.json",
        "assets/data/series_index.json",
        "assets/data/moments_index.json",
        "assets/data/recent_index.json",
        "assets/works/index/*.json",
        "assets/series/index/*.json",
        "assets/moments/index/*.json",
        "assets/data/search/catalogue/index.json"
      ]
    }
  ],
  "public_docs_viewer": {
    "config_path": "docs-viewer/config/defaults/docs-viewer-public-config.json",
    "allowed_scope_ids": [
      "library",
      "analysis"
    ]
  },
  "public_html_forbidden_hrefs": [
    "href=\"/studio/\"",
    "href=\"/docs/\"",
    "href=\"/docs/?"
  ],
  "public_source_reference_audit": {
    "scan_paths": [
      "_layouts/**/*.html",
      "_includes/**/*.html",
      "assets/js/**/*.js",
      "assets/css/**/*.css",
      "*.md"
    ],
    "ignore_paths": [],
      "forbidden_substrings": [
        "assets/studio/",
        "/assets/studio/",
        "docs-viewer/generated/docs/studio",
        "/docs-viewer/generated/docs/studio",
        "docs-viewer/generated/search/studio",
        "/docs-viewer/generated/search/studio",
        "href=\"/studio/",
      "href='/studio/",
      "baseurl + '/studio/",
      "baseurl + \"/studio/",
      "href=\"/docs/?scope=studio",
      "href='/docs/?scope=studio"
    ]
  }
}
