                "running_status": "Updating tag aliases...",
                "success_status": "Tag aliases updated.",
                "failed_status": "Tag aliases update failed.",
                "cancelled_status": "Tag aliases update cancelled.",
                "no_change_count_key": "changed"
              },
              "confirmation": {
                "title": "Apply tag alias changes?",
                "body": "This will back up and update Studio tag aliases.",
                "primary_label": "OK",
                "cancel_label": "Cancel"
              },
              "result": {
                "title": "Tag alias update complete",
                "count_text": "{added} added; {overwritten} overwritten; {removed} removed; {unchanged} unchanged; {skipped} skipped; {errors} errors.",
                "count_rows": [
                  {
                    "key": "added",
                    "label": "added"
                  },
                  {
                    "key": "overwritten",
                    "label": "overwritten"
                  },
                  {
                    "key": "removed",
