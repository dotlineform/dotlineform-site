          "input_formats": ["json", "jsonl"],
          "output_formats": [],
          "path_contract": {
            "staging_root": "returned_package_staging_root",
            "source_root": "source_root",
            "backup_root": "backup_root"
          },
          "requires_confirmation": true,
          "apply_actions": [
            {
              "id": "registry_apply",
              "label": "Apply tag registry changes",
              "status": "active",
              "ui": {
                "control_id": "dataSharingReviewApplyTagRegistry",
                "control_selector": "#dataSharingReviewApplyTagRegistry",
                "activity_action_id": "apply-returned-tag-registry",
                "selection_required_message": "Select at least one tag registry row.",
                "preflight_status": "Checking selected tag registry changes...",
                "running_status": "Updating tag registry...",
                "success_status": "Tag registry updated.",
                "failed_status": "Tag registry update failed.",
                "cancelled_status": "Tag registry update cancelled.",
                "no_change_count_key": "changed"
              },
              "confirmation": {
                "title": "Apply tag registry changes?",
                "body": "This will back up and update the Studio tag registry.",
                "primary_label": "OK",
                "cancel_label": "Cancel"
              },
              "result": {
                "title": "Tag registry update complete",
                "count_text": "{added} added; {overwritten} overwritten; {removed} removed; {unchanged} unchanged; {skipped} skipped; {errors} errors.",
                "count_rows": [
                  {
                    "key": "added",
                    "label": "added"
