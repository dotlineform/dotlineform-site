                  {
                    "key": "overwritten",
                    "label": "overwritten"
                  },
                  {
                    "key": "removed",
                    "label": "removed"
                  },
                  {
                    "key": "unchanged",
                    "label": "unchanged"
                  },
                  {
                    "key": "skipped",
