{
  "schema": "catalogue_field_registry_v1",
  "status": "task_2_initial_registry",
  "last_updated": "2026-05-02",
  "source_doc": "/docs/?scope=studio&doc=site-request-field-aware-build-scoping",
  "inventory_doc": "/docs/?scope=studio&doc=site-request-field-aware-build-scoping-inventory",
  "description": "Field-to-artifact dependency registry for catalogue source edits. Task 2 records current selected behavior and target behavior; later tasks wire the target rules into build planning.",
  "artifact_families": {
    "source-json": "Canonical Studio catalogue source JSON.",
    "studio-lookup": "Studio read payloads and search/open payloads under studio/data/generated/catalogue-lookup/.",
    "work-page": "Metadata-free public work route shell.",
    "work-details-page": "Metadata-free public work-detail route shell.",
    "series-page": "Metadata-free public series route shell.",
    "moment-page": "Metadata-free public moment route shell.",
    "work-json": "Focused public work JSON.",
    "works-index-json": "Aggregate public works index JSON.",
    "work-storage-index-json": "Studio storage lookup derived from work storage metadata.",
    "series-json": "Focused public series JSON.",
    "series-index-json": "Aggregate public series index JSON.",
    "recent-index-json": "Public recent-publications index.",
    "moment-json": "Focused public moment JSON.",
    "moments-index-json": "Aggregate public moments index JSON.",
    "catalogue-search": "Public catalogue search index.",
    "local-media": "Local media staging, derivative generation, and public thumbnail copy outputs."
  },
  "rule_statuses": {
    "current": "Artifacts selected or refreshed by the current broad planner, current lookup invalidation, or current media workflow.",
    "target": "Artifacts that should be selected by field-aware planning after Tasks 3-6."
  },
  "defaults": {
    "unknown_field": {
      "target": {
        "fallback": true,
        "artifacts_by_record_family": {
          "work": ["source-json", "studio-lookup", "work-page", "work-json", "works-index-json", "series-page", "series-json", "series-index-json", "recent-index-json", "catalogue-search", "local-media"],
          "work_detail": ["source-json", "studio-lookup", "work-details-page", "work-json", "catalogue-search", "local-media"],
          "series": ["source-json", "studio-lookup", "series-page", "series-json", "series-index-json", "works-index-json", "recent-index-json", "catalogue-search"],
          "moment": ["source-json", "moment-page", "moment-json", "moments-index-json", "catalogue-search", "local-media"]
        },
        "reason": "Unknown source fields use conservative fallback until explicitly classified."
      }
    },
    "mixed_dependency_classes": {
      "target": {
        "fallback": true,
        "artifacts_by_record_family": {
          "work": ["source-json", "studio-lookup", "work-page", "work-json", "works-index-json", "series-page", "series-json", "series-index-json", "recent-index-json", "catalogue-search", "local-media"],
          "work_detail": ["source-json", "studio-lookup", "work-details-page", "work-json", "catalogue-search", "local-media"],
          "series": ["source-json", "studio-lookup", "series-page", "series-json", "series-index-json", "works-index-json", "recent-index-json", "catalogue-search"],
          "moment": ["source-json", "moment-page", "moment-json", "moments-index-json", "catalogue-search", "local-media"]
        },
        "reason": "Mixed edits spanning dependency classes use conservative fallback until the planner can combine field rules safely."
      }
    }
  },
  "rules": [
    {
      "id": "work_identity",
      "record_family": "work",
      "operation": "create_delete_identity",
      "fields": ["work_id"],
      "current": {
        "artifacts": ["source-json", "studio-lookup", "work-page", "work-json", "works-index-json", "series-page", "series-index-json", "recent-index-json", "catalogue-search", "local-media"],
        "fallback": true
      },
      "target": {
        "artifacts": ["source-json", "studio-lookup", "work-page", "work-json", "works-index-json", "series-index-json", "recent-index-json", "catalogue-search", "local-media"],
        "fallback": false,
        "reason": "Work identity controls route creation/removal, public payload identity, aggregate membership references, search identity, and media output names."
      }
    },
    {
      "id": "work_publish_membership",
      "record_family": "work",
      "operation": "metadata_update",
      "fields": ["status", "published_date", "series_ids"],
      "current": {
        "artifacts": ["source-json", "studio-lookup", "work-page", "work-json", "series-page", "series-index-json", "works-index-json", "recent-index-json", "catalogue-search"],
        "fallback": false
      },
      "target": {
        "artifacts": ["source-json", "studio-lookup", "work-json", "works-index-json", "series-index-json", "recent-index-json", "catalogue-search"],
        "conditional_artifacts": [
          {
            "artifact": "work-page",
            "when": "work is created, deleted, or identity changes"
          },
          {
            "artifact": "series-index-json",
            "when": "old or new related series membership, ordering, or published visibility changes"
          }
        ],
        "fallback": false,
        "reason": "Publication state and membership affect public inclusion, related series membership, /recent/, and search."
      }
    },
    {
      "id": "work_display_core",
      "record_family": "work",
      "operation": "metadata_update",
      "fields": ["title", "year", "year_display"],
      "current": {
        "artifacts": ["source-json", "studio-lookup", "work-page", "work-json", "series-page", "series-index-json", "works-index-json", "recent-index-json", "catalogue-search"],
        "fallback": false
      },
      "target": {
        "artifacts": ["source-json", "studio-lookup", "work-json", "works-index-json", "recent-index-json", "catalogue-search"],
        "conditional_artifacts": [
          {
            "artifact": "series-index-json",
            "when": "a related series sort_fields rule uses the changed field"
          }
        ],
        "fallback": false,
        "reason": "Core display fields are serialized to focused work JSON, aggregate works index, /recent/ entries, and catalogue search."
      }
    },
    {
      "id": "work_search_enrichment",
      "record_family": "work",
      "operation": "metadata_update",
      "fields": ["medium_type", "medium_caption"],
      "current": {
        "artifacts": ["source-json", "studio-lookup", "work-page", "work-json", "series-page", "series-index-json", "works-index-json", "recent-index-json", "catalogue-search"],
        "fallback": false
      },
      "target": {
        "artifacts": ["source-json", "studio-lookup", "work-json", "catalogue-search"],
        "fallback": false,
        "reason": "Medium fields enrich focused work metadata and catalogue search, but do not affect series membership or aggregate work cards."
      }
    },
    {
      "id": "work_local_public_metadata",
      "record_family": "work",
      "operation": "metadata_update",
      "fields": ["duration", "artist", "width_cm", "height_cm", "depth_cm", "downloads", "links"],
      "current": {
        "artifacts": ["source-json", "studio-lookup", "work-page", "work-json", "series-page", "series-index-json", "works-index-json", "recent-index-json", "catalogue-search"],
        "fallback": false
      },
      "target": {
        "artifacts": ["source-json", "studio-lookup", "work-json"],
        "fallback": false,
        "reason": "These fields are focused work metadata and should not select series artifacts or broad aggregate indexes unless a future public artifact starts serializing them."
      }
    },
    {
      "id": "work_storage",
      "record_family": "work",
      "operation": "metadata_update",
      "fields": ["storage_location"],
      "current": {
        "artifacts": ["source-json", "studio-lookup", "work-page", "work-json", "series-page", "series-index-json", "works-index-json", "recent-index-json", "catalogue-search"],
        "fallback": false
      },
      "target": {
        "artifacts": ["source-json", "studio-lookup", "work-json", "work-storage-index-json"],
        "fallback": false,
        "reason": "Storage metadata is serialized to focused work runtime data and the Studio storage lookup only."
      }
    },
    {
      "id": "work_media_source",
      "record_family": "work",
      "operation": "metadata_update",
      "fields": ["project_folder", "project_subfolder", "project_filename"],
      "current": {
        "artifacts": ["source-json", "studio-lookup", "work-page", "work-json", "series-page", "series-index-json", "works-index-json", "recent-index-json", "catalogue-search", "local-media"],
        "fallback": false
      },
      "target": {
        "artifacts": ["source-json", "studio-lookup", "local-media"],
        "conditional_artifacts": [
          {
            "artifact": "work-json",
            "when": "media refresh changes derived width_px or height_px"
          }
        ],
        "fallback": false,
        "reason": "Work source media folder and filename fields control Studio source-image editing, media readiness, and derivative generation; JSON rebuild follows only if derived dimensions change."
      }
    },
    {
      "id": "work_derived_image_dimensions",
      "record_family": "work",
      "operation": "derived_update",
      "fields": ["width_px", "height_px"],
      "current": {
        "artifacts": ["source-json", "studio-lookup", "work-page", "work-json", "series-page", "series-index-json", "works-index-json", "recent-index-json", "catalogue-search"],
        "fallback": false
      },
      "target": {
        "artifacts": ["source-json", "studio-lookup", "work-json"],
        "fallback": false,
        "reason": "Pixel dimensions are derived from image files and affect focused work image aspect ratio."
      }
    },
    {
      "id": "work_editor_only",
      "record_family": "work",
      "operation": "metadata_update",
      "fields": ["provenance"],
      "current": {
        "artifacts": ["source-json", "studio-lookup"],
        "fallback": false
      },
      "target": {
        "artifacts": ["source-json", "studio-lookup"],
        "fallback": false,
        "reason": "These fields are Studio/editor-only and are not published to public runtime artifacts."
      }
    },
    {
      "id": "work_detail_identity",
      "record_family": "work_detail",
      "operation": "create_delete_identity",
      "fields": ["detail_uid", "work_id", "detail_id"],
      "current": {
        "artifacts": ["source-json", "studio-lookup", "work-details-page", "work-json", "catalogue-search", "local-media"],
        "fallback": true
      },
      "target": {
        "artifacts": ["source-json", "studio-lookup", "work-details-page", "work-json", "local-media"],
        "fallback": false,
        "reason": "Detail identity controls route creation/removal, parent work sections, lookup identity, and media output names."
      }
    },
    {
      "id": "work_detail_public_metadata",
      "record_family": "work_detail",
      "operation": "metadata_update",
      "fields": ["title"],
      "current": {
        "artifacts": ["source-json", "studio-lookup", "work-details-page", "work-json", "catalogue-search", "local-media"],
        "fallback": true
      },
      "target": {
        "artifacts": ["source-json", "studio-lookup", "work-json"],
        "conditional_artifacts": [
          {
            "artifact": "work-details-page",
            "when": "detail is created, deleted, or identity changes"
          }
        ],
        "fallback": false,
        "reason": "Detail metadata affects the parent focused work payload and Studio lookup; route shells are identity-only."
      }
    },
    {
      "id": "work_detail_media_source",
      "record_family": "work_detail",
      "operation": "metadata_update",
      "fields": ["details_subfolder", "project_filename"],
      "current": {
        "artifacts": ["source-json", "studio-lookup", "work-details-page", "work-json", "catalogue-search", "local-media"],
        "fallback": true
      },
      "target": {
        "artifacts": ["source-json", "studio-lookup", "local-media"],
        "conditional_artifacts": [
          {
            "artifact": "work-json",
            "when": "media refresh changes derived detail width_px or height_px"
          }
        ],
        "fallback": false,
        "reason": "Detail source media folder and filename fields control Studio source-image editing, media readiness, and derivative generation; JSON rebuild follows only if derived dimensions change."
      }
    },
    {
      "id": "work_detail_section_metadata",
      "record_family": "work_detail",
      "operation": "metadata_update",
      "fields": ["section_id", "section_title", "sort_order"],
      "current": {
        "artifacts": ["source-json", "studio-lookup", "work-json"],
        "fallback": false
      },
      "target": {
        "artifacts": ["source-json", "studio-lookup", "work-json"],
        "fallback": false,
        "reason": "Detail section metadata controls parent work JSON grouping, section labels, and section ordering without affecting source media generation."
      }
    },
    {
      "id": "work_detail_dimensions",
      "record_family": "work_detail",
      "operation": "derived_update",
      "fields": ["width_px", "height_px"],
      "current": {
        "artifacts": ["source-json", "studio-lookup", "work-json"],
        "fallback": true
      },
      "target": {
        "artifacts": ["source-json", "studio-lookup", "work-json"],
        "fallback": false,
        "reason": "Detail dimensions are serialized into the parent focused work payload."
      }
    },
    {
      "id": "series_identity",
      "record_family": "series",
      "operation": "create_delete_identity",
      "fields": ["series_id"],
      "current": {
        "artifacts": ["source-json", "studio-lookup", "series-page", "series-json", "series-index-json", "works-index-json", "recent-index-json", "catalogue-search"],
        "fallback": true
      },
      "target": {
        "artifacts": ["source-json", "studio-lookup", "series-page", "series-json", "series-index-json", "works-index-json", "recent-index-json", "catalogue-search"],
        "fallback": false,
        "reason": "Series identity controls route creation/removal, related work membership references, public aggregate indexes, recent entries, and search."
      }
    },
    {
      "id": "series_display_search",
      "record_family": "series",
      "operation": "metadata_update",
      "fields": ["title", "series_type", "year", "year_display"],
      "current": {
        "artifacts": ["source-json", "studio-lookup", "series-page", "series-json", "series-index-json", "works-index-json", "recent-index-json", "catalogue-search"],
        "fallback": false
      },
      "target": {
        "artifacts": ["source-json", "studio-lookup", "series-json", "series-index-json", "recent-index-json", "catalogue-search"],
        "fallback": false,
        "reason": "Series display fields affect focused series JSON, aggregate series data, related search entries, and recent display context."
      }
    },
    {
      "id": "series_publish_primary_order",
      "record_family": "series",
      "operation": "metadata_update",
      "fields": ["status", "published_date", "primary_work_id", "sort_fields"],
      "current": {
        "artifacts": ["source-json", "studio-lookup", "series-page", "series-json", "series-index-json", "works-index-json", "recent-index-json", "catalogue-search"],
        "fallback": false
      },
      "target": {
        "artifacts": ["source-json", "studio-lookup", "series-json", "series-index-json", "recent-index-json", "catalogue-search"],
        "conditional_artifacts": [
          {
            "artifact": "works-index-json",
            "when": "series status or identity affects public work membership context"
          }
        ],
        "fallback": false,
        "reason": "Publication state, primary work, and ordering affect public series membership, thumbnails, recent pruning, and search."
      }
    },
    {
      "id": "moment_identity",
      "record_family": "moment",
      "operation": "create_delete_identity",
      "fields": ["moment_id"],
      "current": {
        "artifacts": ["source-json", "moment-page", "moment-json", "moments-index-json", "catalogue-search", "local-media"],
        "fallback": true
      },
      "target": {
        "artifacts": ["source-json", "moment-page", "moment-json", "moments-index-json", "catalogue-search", "local-media"],
        "fallback": false,
        "reason": "Moment identity controls route creation/removal, focused payload, aggregate index, search identity, and media output names."
      }
    },
    {
      "id": "moment_display_search",
      "record_family": "moment",
      "operation": "metadata_update",
      "fields": ["title", "date", "date_display", "image_alt"],
      "current": {
        "artifacts": ["source-json", "moment-page", "moment-json", "moments-index-json", "catalogue-search"],
        "fallback": true
      },
      "target": {
        "artifacts": ["source-json", "moment-json", "moments-index-json", "catalogue-search"],
        "fallback": false,
        "reason": "Moment display metadata is serialized to focused moment JSON, aggregate moments index, and catalogue search; route shells are identity-only."
      }
    },
    {
      "id": "moment_publish_state",
      "record_family": "moment",
      "operation": "metadata_update",
      "fields": ["status", "published_date"],
      "current": {
        "artifacts": ["source-json", "moment-page", "moment-json", "moments-index-json", "catalogue-search"],
        "fallback": true
      },
      "target": {
        "artifacts": ["source-json", "moment-json", "moments-index-json", "catalogue-search"],
        "fallback": false,
        "reason": "Moment publication state controls public inclusion in focused and aggregate moment artifacts and search."
      }
    },
    {
      "id": "moment_media_source",
      "record_family": "moment",
      "operation": "metadata_update",
      "fields": ["source_image_file"],
      "current": {
        "artifacts": ["source-json", "moment-page", "moment-json", "moments-index-json", "catalogue-search", "local-media"],
        "fallback": true
      },
      "target": {
        "artifacts": ["source-json", "local-media"],
        "conditional_artifacts": [
          {
            "artifact": "moment-json",
            "when": "media refresh changes source image availability or dimensions"
          },
          {
            "artifact": "moments-index-json",
            "when": "thumbnail availability changes"
          },
          {
            "artifact": "catalogue-search",
            "when": "public moment index data changes"
          }
        ],
        "fallback": false,
        "reason": "Moment source image controls media readiness and derivatives; JSON/search follow public image availability changes."
      }
    }
  ],
  "retired_fields": [
    {
      "record_family": "work",
      "field": "work_prose_file",
      "removed_in": "Task 1A",
      "replacement": "studio/data/canonical/catalogue-markdown/works/<work_id>.md"
    },
    {
      "record_family": "work",
      "field": "series_title",
      "removed_in": "Task 1A",
      "replacement": "derived from related series records"
    },
    {
      "record_family": "series",
      "field": "series_prose_file",
      "removed_in": "Task 1A",
      "replacement": "studio/data/canonical/catalogue-markdown/series/<series_id>.md"
    }
  ]
}
